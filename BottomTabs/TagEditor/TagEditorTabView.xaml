<UserControl
    x:Class="IndigoMovieManager.BottomTabs.TagEditor.TagEditorTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource BottomTabRootUserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="RegisteredActionChipBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#1A3949AB" />
            <Setter Property="BorderBrush" Value="#663949AB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="RegisteredActionChipButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF3949AB" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="RegisteredActionChipCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF3949AB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="11">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegisteredTagAddButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#1A3949AB" />
            <Setter Property="BorderBrush" Value="#663949AB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF3949AB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterChipToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1A3949AB" />
            <Setter Property="BorderBrush" Value="#663949AB" />
            <Setter Property="Foreground" Value="#FF3949AB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"
                                    Kind="Check"
                                    Visibility="Collapsed"
                                    x:Name="CheckIcon" />
                                <ContentPresenter
                                    VerticalAlignment="Center"
                                    RecognizesAccessKey="True" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                                <Setter Property="Background" Value="#1F3949AB" />
                                <Setter Property="BorderBrush" Value="#993949AB" />
                                <Setter Property="Foreground" Value="#FF3949AB" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#AA3949AB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="SelectedTagsDropHost"
            Grid.Column="0"
            Padding="8"
            Background="Transparent"
            BorderBrush="#22000000"
            BorderThickness="1"
            CornerRadius="6">
            <Grid
                x:Name="SelectedTagsDropSurface"
                Background="Transparent"
                >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="180" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    x:Name="MovieNameTextBlock"
                    FontSize="16"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap" />

                <Border
                    x:Name="SelectedMovieThumbnailPanel"
                    Grid.Row="2"
                    Background="#11000000"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Image
                            x:Name="ThumbnailImage"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            MaxWidth="{Binding ActualWidth, ElementName=SelectedMovieThumbnailPanel}"
                            MaxHeight="{Binding ActualHeight, ElementName=SelectedMovieThumbnailPanel}"
                            Stretch="Uniform"
                            Source="{Binding ThumbPathGrid}" />
                        <TextBlock
                            x:Name="ThumbnailPlaceholderTextBlock"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.7"
                            Text="選択中動画はありません。" />
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="登録済みタグ" />

                    <Button
                        x:Name="AddRegisteredTagButton"
                        Grid.Column="1"
                        Click="AddRegisteredTagButton_Click"
                        Style="{StaticResource RegisteredTagAddButtonStyle}">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Kind="Plus" />
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            x:Name="DropHintTextBlock"
                            Margin="0,0,0,8"
                            Opacity="0.65"
                            Text="登録済みタグをここで確認できます" />

                        <ItemsControl x:Name="RegisteredTagsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RegisteredActionChipBorderStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            Click="RegisteredTagSearchButton_Click"
                                            Content="{Binding}"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource RegisteredActionChipButtonStyle}" />
                                        <Button
                                            Click="RegisteredTagRemoveButton_Click"
                                            Style="{StaticResource RegisteredActionChipCloseButtonStyle}">
                                            <materialDesign:PackIcon
                                                Width="22"
                                                Height="22"
                                                Kind="CloseCircle" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="2" Padding="8" BorderBrush="#22000000" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontWeight="SemiBold"
                    Text="検索タグ" />

                <TextBlock
                    Grid.Row="2"
                    Margin="0,0,0,8"
                    Opacity="0.65"
                    Text="クリックで検索条件へ追加・解除"
                    VerticalAlignment="Top" />

                <ItemsControl Grid.Row="2" Margin="0,28,0,0" x:Name="PaletteItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton
                                Click="PaletteButton_Click"
                                Content="{Binding TagName}"
                                IsChecked="{Binding IsActive, Mode=OneWay}"
                                Style="{StaticResource FilterChipToggleButtonStyle}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
