<UserControl
    x:Class="IndigoMovieManager.BottomTabs.ThumbnailProgress.ThumbnailProgressTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prop="clr-namespace:IndigoMovieManager.Properties"
    Style="{StaticResource BottomTabRootUserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- UserControl 単体で初期化しても落ちないように、必要なコンバータはローカルに持つ。 -->
        <c:ThumbnailProgressPreviewConverter x:Key="thumbnailProgressPreviewConverter" />
        <Style x:Key="CompactSectionBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style x:Key="CompactLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,6,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
        </Style>
        <Style x:Key="CompactValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="WorkerPanelDetailTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasDetailText, Mode=OneWay}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WorkerPanelStatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#FFF3F3F3" />
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style x:Key="WorkerPanelStatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style
            x:Key="WorkerPanelRescueStatusBadgeBorderStyle"
            BasedOn="{StaticResource WorkerPanelStatusBadgeBorderStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText, Mode=OneWay}" Value="救済中">
                    <Setter Property="Background" Value="#FFF8E3E3" />
                    <Setter Property="BorderBrush" Value="#FFD8A3A3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="WorkerPanelThreadStatusBadgeBorderStyle"
            BasedOn="{StaticResource WorkerPanelStatusBadgeBorderStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText, Mode=OneWay}" Value="処理中">
                    <Setter Property="Background" Value="#FFE4F5E3" />
                    <Setter Property="BorderBrush" Value="#FF9FC99B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="WorkerPanelCardTemplate">
            <Border
                Width="194"
                Margin="2"
                Padding="4"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1"
                CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}" />
                        <Setter Property="Opacity" Value="1.0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="False">
                                <Setter Property="Opacity" Value="0.70" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Grid Margin="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="11"
                            FontWeight="Bold"
                            Text="{Binding WorkerLabel, Mode=OneWay}" />
                        <Border
                            Grid.Column="1"
                            Style="{StaticResource WorkerPanelThreadStatusBadgeBorderStyle}">
                            <TextBlock
                                Style="{StaticResource WorkerPanelStatusBadgeTextStyle}"
                                Text="{Binding StatusText, Mode=OneWay}" />
                        </Border>
                    </Grid>
                    <TextBlock
                        Margin="0,1,0,2"
                        Text="{Binding MovieName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding MovieName, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource WorkerPanelDetailTextStyle}"
                        Text="{Binding DetailText, Mode=OneWay}" />
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                        <Image
                            Height="64"
                            Stretch="Uniform">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource thumbnailProgressPreviewConverter}" ConverterParameter="64">
                                    <Binding Mode="OneWay" Path="PreviewCacheKey" />
                                    <Binding Mode="OneWay" Path="PreviewRevision" />
                                    <Binding Mode="OneWay" Path="PreviewImagePath" />
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="RescueWorkerPanelCardTemplate">
            <Border
                Margin="0,0,0,6"
                Padding="5"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1"
                CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}" />
                        <Setter Property="Opacity" Value="1.0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="False">
                                <Setter Property="Opacity" Value="0.70" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Grid Margin="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Text="{Binding WorkerLabel, Mode=OneWay}" />
                        <Border
                            Grid.Column="1"
                            Style="{StaticResource WorkerPanelRescueStatusBadgeBorderStyle}">
                            <TextBlock
                                Style="{StaticResource WorkerPanelStatusBadgeTextStyle}"
                                Text="{Binding StatusText, Mode=OneWay}" />
                        </Border>
                    </Grid>
                    <TextBlock
                        Margin="0,1,0,3"
                        Text="{Binding MovieName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding MovieName, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource WorkerPanelDetailTextStyle}"
                        Text="{Binding DetailText, Mode=OneWay}" />
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                        <Image
                            Height="68"
                            Stretch="Uniform">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource thumbnailProgressPreviewConverter}" ConverterParameter="68">
                                    <Binding Mode="OneWay" Path="PreviewCacheKey" />
                                    <Binding Mode="OneWay" Path="PreviewRevision" />
                                    <Binding Mode="OneWay" Path="PreviewImagePath" />
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="312" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer
            Grid.Column="0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CompactSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="Bold" Text="サムネイル進捗" />
                        <Grid Margin="0,3,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="124" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource CompactLabelStyle}" Text="キュー / 処理数 / 総作成枚数" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource CompactValueStyle}"
                                Text="{Binding ThumbnailProgress.CreatedQueueText}" />

                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource CompactLabelStyle}"
                                Text="登録待ち" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource CompactValueStyle}"
                                Text="{Binding PendingMovieRecs.Count, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="2"
                                Style="{StaticResource CompactLabelStyle}"
                                Text="現在 / 最大 / 論理コア" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource CompactValueStyle}"
                                Margin="0"
                                Text="{Binding ThumbnailProgress.ThreadText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="Bold" Text="設定" />
                        <Grid Margin="0,2,0,0">
                            <Grid.Resources>
                                <Style x:Key="CompactSettingLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CompactLabelStyle}">
                                    <Setter Property="Margin" Value="0,0,6,1" />
                                </Style>
                                <Style x:Key="CompactSettingValueStyle" TargetType="TextBlock" BasedOn="{StaticResource CompactValueStyle}">
                                    <Setter Property="Margin" Value="0,0,0,1" />
                                </Style>
                                <Style x:Key="CompactSettingRadioStyle" TargetType="RadioButton">
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                                </Style>
                                <Style x:Key="CompactSettingCheckBoxStyle" TargetType="CheckBox">
                                    <Setter Property="Margin" Value="0,0,0,1" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="MinWidth" Value="18" />
                                    <Setter Property="MinHeight" Value="18" />
                                </Style>
                                <Style x:Key="CompactSettingSliderStyle" TargetType="Slider" BasedOn="{StaticResource MaterialDesignDiscreteSlider}">
                                    <Setter Property="Margin" Value="4,0,0,1" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Height" Value="24" />
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="34" />
                                <RowDefinition Height="34" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="124" />
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Style="{StaticResource CompactSettingLabelStyle}"
                                Text="サムネイルを縮小"
                                ToolTip="縮小する=WBのサムネサイズに準拠。縮小しない=1枚あたり上限320x240です。" />
                            <CheckBox
                                x:Name="ThumbnailProgressResizeThumbCheckBox"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Style="{StaticResource CompactSettingCheckBoxStyle}"
                                VerticalAlignment="Center"
                                IsChecked="{Binding Source={x:Static prop:Settings.Default}, Path=IsResizeThumb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource CompactSettingLabelStyle}"
                                Text="GPUを使う"
                                ToolTip="速度差は小さい場合がありますが、CPU負荷を下げたい時に有効です。" />
                            <CheckBox
                                x:Name="ThumbnailProgressGpuDecodeEnabled"
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Style="{StaticResource CompactSettingCheckBoxStyle}"
                                VerticalAlignment="Center"
                                Click="ThumbnailProgressGpuDecodeEnabled_Click"
                                IsChecked="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailGpuDecodeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="2"
                                Style="{StaticResource CompactSettingLabelStyle}"
                                Text="並列作成数" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource CompactSettingValueStyle}"
                                HorizontalAlignment="Right"
                                Text="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailParallelism}" />
                            <Slider
                                x:Name="sliderThumbnailProgressParallelism"
                                Grid.Row="2"
                                Grid.Column="2"
                                Maximum="24"
                                Minimum="1"
                                SmallChange="1"
                                Style="{StaticResource CompactSettingSliderStyle}"
                                TickFrequency="1"
                                ValueChanged="ThumbnailProgressParallelismSlider_ValueChanged"
                                Value="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailParallelism, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="3"
                                Style="{StaticResource CompactSettingLabelStyle}"
                                Text="巨大動画判定(GB)"
                                ToolTip="この値以上の動画を低速レーンへ寄せます。" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Style="{StaticResource CompactSettingValueStyle}"
                                HorizontalAlignment="Right"
                                Text="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailSlowLaneMinGb}" />
                            <Slider
                                x:Name="sliderThumbnailProgressSlowLaneMinGb"
                                Grid.Row="3"
                                Grid.Column="2"
                                Maximum="200"
                                Minimum="1"
                                SmallChange="1"
                                Style="{StaticResource CompactSettingSliderStyle}"
                                TickFrequency="1"
                                ValueChanged="ThumbnailProgressSlowLaneMinGbSlider_ValueChanged"
                                Value="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailSlowLaneMinGb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="4"
                                Style="{StaticResource CompactSettingLabelStyle}"
                                Text="プリセット" />
                            <StackPanel
                                Grid.Row="4"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,1"
                                Orientation="Horizontal">
                                <RadioButton
                                    x:Name="ThumbnailProgressPresetLowSpeedRadioButton"
                                    Style="{StaticResource CompactSettingRadioStyle}"
                                    Checked="ThumbnailProgressPresetLowLoadRadioButton_Checked"
                                    Content="低速"
                                    GroupName="ThumbnailProgressPresetGroup"
                                    ToolTip="巨大動画寄り / 並列少なめ" />
                                <RadioButton
                                    x:Name="ThumbnailProgressPresetNormalRadioButton"
                                    Style="{StaticResource CompactSettingRadioStyle}"
                                    Checked="ThumbnailProgressPresetNormalRadioButton_Checked"
                                    Content="普通"
                                    GroupName="ThumbnailProgressPresetGroup"
                                    ToolTip="標準バランス" />
                                <RadioButton
                                    x:Name="ThumbnailProgressPresetFastRadioButton"
                                    Style="{StaticResource CompactSettingRadioStyle}"
                                    Checked="ThumbnailProgressPresetFastRadioButton_Checked"
                                    Content="高速"
                                    GroupName="ThumbnailProgressPresetGroup"
                                    ToolTip="通常動画を軽快に回す / 並列多め" />
                            </StackPanel>

                            <TextBlock
                                Grid.Row="5"
                                Grid.ColumnSpan="3"
                                Margin="0,-1,0,0"
                                FontSize="10"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Text="Ctrl + + で並列数を増加 / Ctrl + - で並列数を減少"
                                TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <ContentControl
                    Content="{Binding ThumbnailProgress.RescueWorkerPanel}"
                    ContentTemplate="{StaticResource RescueWorkerPanelCardTemplate}" />
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer
            Grid.Column="2"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl
                ItemTemplate="{StaticResource WorkerPanelCardTemplate}"
                ItemsSource="{Binding ThumbnailProgress.WorkerPanels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
