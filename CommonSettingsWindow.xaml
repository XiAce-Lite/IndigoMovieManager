<Window
    x:Class="IndigoMovieManager.CommonSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prop="clr-namespace:IndigoMovieManager.Properties"
    Title="共通設定"
    Width="800"
    Height="720"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <materialDesign:ColorZone>
            <StackPanel Margin="10" Orientation="Vertical">
                <Button
                    x:Name="BtnReturn"
                    Margin="10,6,0,6"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="BtnReturn_Click"
                    Content="戻る(_R)"
                    FontWeight="Normal" />

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="起動時、最後に開いた管理ファイルを開く"
                        FontSize="14" />
                    <CheckBox
                        x:Name="AutoOpen"
                        Width="Auto"
                        FontSize="14"
                        IsChecked="{Binding AutoOpen, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="270"
                        Margin="30,5,0,5"
                        Content="最後の管理ファイル"
                        FontSize="14"
                        Foreground="Gray" />
                    <Label
                        Margin="10,5,5,5"
                        Content="{Binding LastDoc, Source={x:Static prop:Settings.Default}}"
                        FontSize="14"
                        Foreground="Gray" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="既定の再生プレイヤー"
                        FontSize="14" />
                    <TextBox
                        x:Name="DefaultPlayerPath"
                        Width="400"
                        Margin="5"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        FontSize="14"
                        IsReadOnly="True"
                        Text="{Binding DefaultPlayerPath, Source={x:Static prop:Settings.Default}}"
                        ToolTip="{Binding DefaultPlayerPath}" />
                    <Button
                        x:Name="OpenDialogPlayer"
                        Width="30"
                        Height="30"
                        Click="OpenDialogPlayer_Click"
                        Content="{materialDesign:PackIcon Kind=FolderOpen}"
                        Style="{StaticResource MaterialDesignIconButton}" />

                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="再生プレイヤーパラメータ"
                        FontSize="14"
                        ToolTip="&lt;ms&gt;と&lt;file&gt;の置換のみ対応" />
                    <ComboBox
                        x:Name="DefaultPlayerParam"
                        Width="400"
                        Margin="5"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        FontSize="14"
                        IsEditable="True"
                        Text="{Binding DefaultPlayerParam, Source={x:Static prop:Settings.Default}}"
                        ToolTip="&lt;ms&gt;と&lt;file&gt;の置換のみ対応" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="終了時の確認"
                        FontSize="14" />
                    <CheckBox
                        x:Name="ConfirmExit"
                        Width="Auto"
                        FontSize="14"
                        IsChecked="{Binding ConfirmExit, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="Delキー押下時の処理"
                        FontSize="14" />
                    <ComboBox
                        x:Name="DeleteKeyActionMode"
                        Width="260"
                        FontSize="14"
                        SelectedIndex="{Binding DeleteKeyActionMode, Source={x:Static prop:Settings.Default}}">
                        <ComboBoxItem Content="登録解除" />
                        <ComboBoxItem Content="動画削除（ゴミ箱）" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="サムネイルを縮小する"
                        FontSize="14"
                        ToolTip="※縮小する＝WBのサムネサイズに準拠。縮小しない＝1枚辺り上限320x240です。" />
                    <CheckBox
                        x:Name="IsResizeThumb"
                        Width="Auto"
                        FontSize="14"
                        IsChecked="{Binding IsResizeThumb, Source={x:Static prop:Settings.Default}}"
                        ToolTip="※縮小する＝WBのサムネサイズに準拠。縮小しない＝1枚辺り上限320x240です。" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="サムネイルGPUデコードを使う"
                        FontSize="14"
                        ToolTip="速度差は小さい場合がありますが、CPU負荷を下げたいときに有効です。" />
                    <CheckBox
                        x:Name="ThumbnailGpuDecodeEnabled"
                        Width="Auto"
                        FontSize="14"
                        IsChecked="{Binding ThumbnailGpuDecodeEnabled, Source={x:Static prop:Settings.Default}}"
                        ToolTip="速度差は小さい場合がありますが、CPU負荷を下げたいときに有効です。" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="Everything連携モード"
                        FontSize="14"
                        ToolTip="OFF:無効 / AUTO:検知できる時だけ利用 / ON:常に利用を試行（失敗時は通常監視へフォールバック）" />
                    <ComboBox
                        x:Name="EverythingIntegrationMode"
                        Width="180"
                        FontSize="14"
                        SelectedIndex="{Binding EverythingIntegrationMode, Source={x:Static prop:Settings.Default}}"
                        ToolTip="OFF:無効 / AUTO:検知できる時だけ利用 / ON:常に利用を試行（失敗時は通常監視へフォールバック）">
                        <ComboBoxItem Content="OFF（使わない）" />
                        <ComboBoxItem Content="AUTO（推奨）" />
                        <ComboBoxItem Content="ON（常に試行）" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="検索プロバイダ（再起動後に反映）"
                        FontSize="14"
                        ToolTip="everything: 既存Everything IPC / everythinglite: EverythingLite実装。変更を有効化するにはアプリ再起動が必要です。" />
                    <ComboBox
                        x:Name="FileIndexProviderSelector"
                        Width="220"
                        FontSize="14"
                        SelectedValuePath="Tag"
                        ToolTip="この設定は起動時に読み込まれます。切替後はアプリを再起動してください。">
                        <ComboBoxItem Tag="everything" Content="everything（既存）" />
                        <ComboBoxItem Tag="everythinglite" Content="everythinglite（新実装）" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="最近開いた管理ファイルに表示する数"
                        FontSize="14" />
                    <TextBlock
                        x:Name="RecentFiles"
                        Width="50"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="{Binding RecentFilesCount, Source={x:Static prop:Settings.Default}}" />
                    <Slider
                        x:Name="slider"
                        Width="100"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Maximum="30"
                        Minimum="1"
                        Style="{StaticResource MaterialDesignDiscreteSlider}"
                        TickFrequency="1"
                        Value="{Binding RecentFilesCount, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="サムネイル並列作成数"
                        FontSize="14" />
                    <TextBlock
                        x:Name="ThumbnailParallelismText"
                        Width="50"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="{Binding ThumbnailParallelism, Source={x:Static prop:Settings.Default}}" />
                    <Slider
                        x:Name="sliderThumbnailParallelism"
                        Width="100"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Maximum="24"
                        Minimum="1"
                        Style="{StaticResource MaterialDesignDiscreteSlider}"
                        TickFrequency="1"
                        Value="{Binding ThumbnailParallelism, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="優先レーン上限サイズ(MB)"
                        FontSize="14"
                        ToolTip="この値以下の動画を優先Threadへ優先割り当てします。" />
                    <TextBlock
                        x:Name="ThumbnailPriorityLaneMaxMbText"
                        Width="60"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="{Binding ThumbnailPriorityLaneMaxMb, Source={x:Static prop:Settings.Default}}" />
                    <Slider
                        x:Name="sliderThumbnailPriorityLaneMaxMb"
                        Width="140"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Maximum="4096"
                        Minimum="50"
                        Style="{StaticResource MaterialDesignDiscreteSlider}"
                        TickFrequency="50"
                        Value="{Binding ThumbnailPriorityLaneMaxMb, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="低速レーン開始サイズ(GB)"
                        FontSize="14"
                        ToolTip="この値以上の動画を低速Threadへ優先割り当てします。" />
                    <TextBlock
                        x:Name="ThumbnailSlowLaneMinGbText"
                        Width="60"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="{Binding ThumbnailSlowLaneMinGb, Source={x:Static prop:Settings.Default}}" />
                    <Slider
                        x:Name="sliderThumbnailSlowLaneMinGb"
                        Width="140"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Maximum="1024"
                        Minimum="1"
                        Style="{StaticResource MaterialDesignDiscreteSlider}"
                        TickFrequency="1"
                        Value="{Binding ThumbnailSlowLaneMinGb, Source={x:Static prop:Settings.Default}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <Label
                        Width="300"
                        Margin="5"
                        Content="閾値プリセット"
                        FontSize="14"
                        ToolTip="用途に合わせて優先/低速レーン閾値を一括変更します。" />
                    <Button
                        Width="120"
                        Margin="5,0,0,0"
                        Click="ThumbnailLanePresetLightButton_Click"
                        Content="軽量動画重視"
                        ToolTip="優先:128MB / 低速:1GB / 並列:論理コアの1/2" />
                    <Button
                        Width="100"
                        Margin="8,0,0,0"
                        Click="ThumbnailLanePresetBalancedButton_Click"
                        Content="バランス"
                        ToolTip="優先:512MB / 低速:3GB / 並列:論理コアの1/3" />
                    <Button
                        Width="120"
                        Margin="8,0,0,0"
                        Click="ThumbnailLanePresetLargeButton_Click"
                        Content="巨大動画重視"
                        ToolTip="優先:1024MB / 低速:10GB / 並列:論理コアの1/4" />
                </StackPanel>

            </StackPanel>

        </materialDesign:ColorZone>

    </Grid>
</Window>
