<Window
    x:Class="IndigoMovieManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:IndigoMovieManager"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
    xmlns:prop="clr-namespace:IndigoMovieManager.Properties"
    xmlns:view="clr-namespace:IndigoMovieManager.UserControls"
    xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
    x:Name="window"
    Title="Indigo Movie Manager"
    Width="800"
    Height="Auto"
    mc:Ignorable="d">

    <Window.Resources>
        <c:FileSizeConverter x:Key="FileSizeConverter" />
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
        <c:ThumbnailProgressPreviewConverter x:Key="thumbnailProgressPreviewConverter" />
        <!--  BoolToVisibilityConverter を追加  -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <ContextMenu x:Key="menuContext" FontSize="10">
            <MenuItem
                x:Name="PlayDefault"
                Click="PlayMovie_Click"
                Header="プレイヤーから開く(_E)"
                Icon="{materialDesign:PackIcon Kind=MoviePlay}"
                InputGestureText="ENTER">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="PlayFromThumb"
                Click="PlayMovie_Click"
                Header="サムネイルから開く(_H)"
                Icon="{materialDesign:PackIcon Kind=MoviePlay}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator />
            <MenuItem
                x:Name="TagEdit"
                Click="TagEdit_Click"
                Header="タグ編集(_T)"
                Icon="{materialDesign:PackIcon Kind=Edit}"
                InputGestureText="F6">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="TagAdd"
                Click="TagAdd_Click"
                Header="タグ追加(_A)"
                Icon="{materialDesign:PackIcon Kind=AttachmentAdd}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="TagDelete"
                Click="TagDelete_Click"
                Header="タグ削除(_V)"
                Icon="{materialDesign:PackIcon Kind=RemoveBox}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="TagCopy"
                Click="TagCopy_Click"
                Header="タグコピー(_C)"
                Icon="{materialDesign:PackIcon Kind=ContentCopy}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="TagPaste"
                Click="TagPaste_Click"
                Header="タグ貼り付け(_V)"
                Icon="{materialDesign:PackIcon Kind=ContentPaste}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="ScorePlus"
                Click="MenuScore_Click"
                Header="スコア +1 (_A)"
                Icon="{materialDesign:PackIcon Kind=Plus}"
                InputGestureText="+">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="ScoreMinus"
                Click="MenuScore_Click"
                Header="スコア -1 (_S)"
                Icon="{materialDesign:PackIcon Kind=Minus}"
                InputGestureText="-">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator />
            <MenuItem
                Click="CreateThumb_EqualInterval"
                Header="等間隔サムネイル作成(_I)"
                Icon="{materialDesign:PackIcon Kind=Create}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <!--- ランダムサムネイルと画像からはなしにした
                                                <MenuItem Header="ランダムサムネイル作成(_R)" Icon="{materialDesign:PackIcon Kind=CreateOutline}" />
                                                <MenuItem Header="画像からサムネイル作成(_P)" Icon="{materialDesign:PackIcon Kind=Image}" />
            -->
            <MenuItem
                x:Name="ManualThumbnail"
                Click="ManualThumbnail_Click"
                Header="マニュアルサムネイル作成(_U)"
                Icon="{materialDesign:PackIcon Kind=Manufacturing}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator />
            <MenuItem
                x:Name="DeleteMovie"
                Click="DeleteMovieRecord_Click"
                Header="登録から削除(_D)"
                Icon="{materialDesign:PackIcon Kind=Delete}"
                InputGestureText="DELETE">

                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="FileCopy"
                Click="MenuCopyAndMove_Click"
                Header="ファイルをコピー(_C)"
                Icon="{materialDesign:PackIcon Kind=ContentCopy}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="FileMove"
                Click="MenuCopyAndMove_Click"
                Header="ファイルを移動(_M)"
                Icon="{materialDesign:PackIcon Kind=MoveToInbox}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="DeleteFile"
                Click="DeleteMovieRecord_Click"
                Header="ファイルを削除(_L)"
                Icon="{materialDesign:PackIcon Kind=RemoveCircle}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem
                x:Name="RenameFile"
                Click="RenameFile_Click"
                Header="ファイル名変更(_N)"
                Icon="{materialDesign:PackIcon Kind=Rename}"
                InputGestureText="F2">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator />
            <MenuItem
                Click="OpenParentFolder_Click"
                Header="親フォルダを開く(_F)"
                Icon="{materialDesign:PackIcon Kind=FolderOpen}"
                InputGestureText="F12">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="1" />
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <!-- この辺はウィンドウ作らないといけないので劣後だろうな。
                                                <MenuItem Header="プロパティ(_P)" Icon="{materialDesign:PackIcon Kind=PropertyTag}" InputGestureText="P">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Padding" Value="1" />
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
            -->
        </ContextMenu>

    </Window.Resources>

    <Window.Background>
        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
    </Window.Background>

    <Grid>
        <avalonDock:DockingManager x:Name="uxDockingManager" Margin="0,70,0,0">
            <avalonDock:DockingManager.Theme>
                <avalonDock:Vs2013LightTheme />
            </avalonDock:DockingManager.Theme>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Vertical">
                    <avalonDock:LayoutPanel
                        CanDock="False"
                        CanRepositionItems="False"
                        Orientation="Horizontal">
                        <avalonDock:LayoutDocumentPane
                            x:Name="uxDocumentPane"
                            CanRepositionItems="False"
                            ShowHeader="False">
                            <!--  ドキュメント  ★ここから  -->
                            <avalonDock:LayoutDocument Title="Document1" ContentId="Document1">
                                <TabControl
                                    x:Name="Tabs"
                                    Margin="0,0,0,0"
                                    PreviewKeyDown="Tab_PreviewKeyDown"
                                    SelectionChanged="Tabs_SelectionChangedAsync">

                                    <TabItem
                                        x:Name="TabSmall"
                                        Background="DarkBlue"
                                        Header="Small"
                                        Tag="120x90x3x1">
                                        <ListView
                                            x:Name="SmallList"
                                            Height="Auto"
                                            ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.IsDeferredScrollingEnabled="True"
                                            SelectionChanged="List_SelectionChanged"
                                            SelectionMode="Extended"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <vwp:VirtualizingWrapPanel
                                                        Orientation="Horizontal"
                                                        StretchItems="True"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.VirtualizationMode="Recycling" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>

                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                    <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SmallListItem_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </ListView.ItemContainerStyle>

                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <VirtualizingStackPanel
                                                        Height="Auto"
                                                        Orientation="Vertical"
                                                        ScrollViewer.IsDeferredScrollingEnabled="true"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.VirtualizationMode="Recycling">
                                                        <VirtualizingStackPanel
                                                            Orientation="Horizontal"
                                                            ScrollViewer.IsDeferredScrollingEnabled="true"
                                                            VirtualizingPanel.IsVirtualizing="True"
                                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                                            <Label
                                                                Width="360"
                                                                Height="Auto"
                                                                Background="Black"
                                                                MouseDoubleClick="PlayMovie_Click"
                                                                MouseDown="Label_MouseDown">
                                                                <Image
                                                                    ContextMenu="{StaticResource menuContext}"
                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                                    VirtualizingPanel.VirtualizationMode="Recycling">
                                                                    <Image.Source>
                                                                        <!--
                                                                            Source="{Binding ThumbPathSmall, Converter={StaticResource noLockImageConverter}, ConverterParameter={Binding IsExists}, UpdateSourceTrigger=PropertyChanged}"
                                                                        -->
                                                                        <c:ConverterBindableParameter
                                                                            Binding="{Binding ThumbPathSmall}"
                                                                            Converter="{StaticResource noLockImageConverter}"
                                                                            ConverterParameter="{Binding IsExists}" />
                                                                    </Image.Source>
                                                                </Image>
                                                            </Label>

                                                            <view:SmallDetailControl />

                                                        </VirtualizingStackPanel>

                                                        <ItemsControl
                                                            Height="Auto"
                                                            ItemsSource="{Binding Tag, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                                                            ScrollViewer.CanContentScroll="True"
                                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                            ScrollViewer.IsDeferredScrollingEnabled="True"
                                                            VirtualizingPanel.IsContainerVirtualizable="True"
                                                            VirtualizingPanel.IsVirtualizing="True"
                                                            VirtualizingPanel.ScrollUnit="Pixel"
                                                            VirtualizingPanel.VirtualizationMode="Recycling">

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <view:TagControl DataContext="{Binding}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>

                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel
                                                                        Width="650"
                                                                        Height="Auto"
                                                                        MinHeight="62"
                                                                        MaxHeight="110"
                                                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                        VirtualizingPanel.IsVirtualizing="True"
                                                                        VirtualizingPanel.VirtualizationMode="Recycling" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                        </ItemsControl>
                                                    </VirtualizingStackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </TabItem>

                                    <TabItem
                                        x:Name="TabBig"
                                        Background="DarkBlue"
                                        Header="Big"
                                        Tag="200x150x3x1">
                                        <ListView
                                            x:Name="BigList"
                                            ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.IsDeferredScrollingEnabled="True"
                                            SelectionChanged="List_SelectionChanged"
                                            SelectionMode="Extended"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.ScrollUnit="Pixel"
                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <vwp:VirtualizingWrapPanel
                                                        Orientation="Horizontal"
                                                        StretchItems="True"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.ScrollUnit="Pixel"
                                                        VirtualizingPanel.VirtualizationMode="Recycling" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>

                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                    <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="BigListItem_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </ListView.ItemContainerStyle>

                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <VirtualizingStackPanel
                                                        Orientation="Horizontal"
                                                        ScrollViewer.IsDeferredScrollingEnabled="true"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.VirtualizationMode="Recycling">
                                                        <VirtualizingStackPanel
                                                            Orientation="Vertical"
                                                            VirtualizingPanel.IsVirtualizing="True"
                                                            VirtualizingPanel.ScrollUnit="Pixel"
                                                            VirtualizingPanel.VirtualizationMode="Recycling">

                                                            <view:BigTitleControl DataContext="{Binding}" />

                                                            <Label
                                                                Width="600"
                                                                Height="150"
                                                                MouseDoubleClick="PlayMovie_Click"
                                                                MouseDown="Label_MouseDown">
                                                                <Image
                                                                    ContextMenu="{StaticResource menuContext}"
                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                                    VirtualizingPanel.VirtualizationMode="Recycling">
                                                                    <Image.Source>
                                                                        <!--
                                                                            Source="{Binding ThumbPathBig, Converter={StaticResource noLockImageConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                                        -->
                                                                        <c:ConverterBindableParameter
                                                                            Binding="{Binding ThumbPathBig}"
                                                                            Converter="{StaticResource noLockImageConverter}"
                                                                            ConverterParameter="{Binding IsExists}" />
                                                                    </Image.Source>

                                                                </Image>
                                                            </Label>

                                                        </VirtualizingStackPanel>

                                                        <view:BigDetailControl DataContext="{Binding}" />

                                                    </VirtualizingStackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </TabItem>

                                    <TabItem
                                        x:Name="TabGrid"
                                        Background="DarkBlue"
                                        Header="Grid"
                                        Tag="160x120x1x1">
                                        <ListView
                                            x:Name="GridList"
                                            ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.IsDeferredScrollingEnabled="True"
                                            SelectionChanged="List_SelectionChanged"
                                            SelectionMode="Extended"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <vwp:VirtualizingWrapPanel
                                                        Orientation="Horizontal"
                                                        SpacingMode="BetweenItemsOnly"
                                                        StretchItems="True"
                                                        VirtualizingPanel.IsVirtualizing="True" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>

                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                </Style>
                                            </ListView.ItemContainerStyle>

                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <VirtualizingStackPanel
                                                        Orientation="Vertical"
                                                        ScrollViewer.IsDeferredScrollingEnabled="true"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.VirtualizationMode="Recycling">

                                                        <Label
                                                            Width="160"
                                                            Height="120"
                                                            MouseDoubleClick="PlayMovie_Click"
                                                            MouseDown="Label_MouseDown">
                                                            <Image
                                                                ContextMenu="{StaticResource menuContext}"
                                                                VirtualizingPanel.IsVirtualizing="True"
                                                                VirtualizingPanel.ScrollUnit="Pixel"
                                                                VirtualizingPanel.VirtualizationMode="Recycling">
                                                                <Image.Source>
                                                                    <!--
                                                                        Source="{Binding ThumbPathGrid, Converter={StaticResource noLockImageConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                                    -->
                                                                    <c:ConverterBindableParameter
                                                                        Binding="{Binding ThumbPathGrid}"
                                                                        Converter="{StaticResource noLockImageConverter}"
                                                                        ConverterParameter="{Binding IsExists}" />
                                                                </Image.Source>

                                                            </Image>

                                                        </Label>

                                                        <Grid Width="160">
                                                            <TextBlock Text="{Binding Movie_Name, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Movie_Path}" />
                                                        </Grid>
                                                    </VirtualizingStackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </TabItem>

                                    <TabItem
                                        x:Name="TabList"
                                        Background="DarkBlue"
                                        Header="List"
                                        Tag="56x42x5x1">
                                        <DataGrid
                                            x:Name="ListDataGrid"
                                            AutoGenerateColumns="False"
                                            BeginningEdit="ListDataGrid_BeginningEdit"
                                            CanUserAddRows="False"
                                            EnableColumnVirtualization="True"
                                            EnableRowVirtualization="True"
                                            HorizontalScrollBarVisibility="Visible"
                                            IsReadOnly="True"
                                            ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="List_SelectionChanged"
                                            SelectionMode="Extended"
                                            SelectionUnit="FullRow"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling">

                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="ContextMenu" Value="{StaticResource menuContext}" />
                                                </Style>
                                            </DataGrid.RowStyle>

                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn
                                                    Width="314"
                                                    MinWidth="314"
                                                    CanUserResize="false"
                                                    Header="サムネイル">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type local:MovieRecords}">
                                                            <Label
                                                                Height="Auto"
                                                                MouseDoubleClick="PlayMovie_Click"
                                                                MouseDown="Label_MouseDown">
                                                                <Image
                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                                    VirtualizingPanel.VirtualizationMode="Recycling">
                                                                    <Image.Source>
                                                                        <c:ConverterBindableParameter
                                                                            Binding="{Binding ThumbPathList}"
                                                                            Converter="{StaticResource noLockImageConverter}"
                                                                            ConverterParameter="{Binding IsExists}" />
                                                                    </Image.Source>
                                                                </Image>
                                                            </Label>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn CanUserSort="True" Header="ファイル名">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <VirtualizingStackPanel
                                                                Orientation="Vertical"
                                                                ScrollViewer.IsDeferredScrollingEnabled="true"
                                                                VirtualizingPanel.IsVirtualizing="True"
                                                                VirtualizingPanel.VirtualizationMode="Recycling">

                                                                <TextBlock
                                                                    FontWeight="Bold"
                                                                    Text="{Binding Movie_Name, UpdateSourceTrigger=PropertyChanged}"
                                                                    TextWrapping="Wrap" />

                                                                <ItemsControl
                                                                    Height="Auto"
                                                                    ItemsSource="{Binding Tag, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                                                                    ScrollViewer.CanContentScroll="True"
                                                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                    ScrollViewer.IsDeferredScrollingEnabled="True"
                                                                    VirtualizingPanel.IsContainerVirtualizable="True"
                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                                    VirtualizingPanel.VirtualizationMode="Recycling">

                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <view:TagControl DataContext="{Binding}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>

                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel
                                                                                MinWidth="200"
                                                                                MinHeight="28"
                                                                                MaxWidth="640"
                                                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                                VirtualizingPanel.IsVirtualizing="True"
                                                                                VirtualizingPanel.VirtualizationMode="Recycling" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                </ItemsControl>

                                                            </VirtualizingStackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTextColumn
                                                    Width="90"
                                                    MinWidth="90"
                                                    Binding="{Binding Movie_Size, Converter={StaticResource FileSizeConverter}}"
                                                    CanUserSort="True"
                                                    Header="サイズ"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="80"
                                                    MinWidth="80"
                                                    Binding="{Binding Movie_Length}"
                                                    CanUserSort="True"
                                                    Header="長さ"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="70"
                                                    MinWidth="70"
                                                    Binding="{Binding Score, UpdateSourceTrigger=PropertyChanged}"
                                                    CanUserSort="True"
                                                    Header="スコア"
                                                    IsReadOnly="True">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>

                                                </DataGridTextColumn>
                                                <DataGridTextColumn
                                                    Width="96"
                                                    MinWidth="96"
                                                    Binding="{Binding View_Count, UpdateSourceTrigger=PropertyChanged}"
                                                    CanUserSort="True"
                                                    Header="再生回数"
                                                    IsReadOnly="True">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn
                                                    Width="200"
                                                    MinWidth="200"
                                                    Binding="{Binding Dir, UpdateSourceTrigger=PropertyChanged}"
                                                    CanUserSort="True"
                                                    Header="フォルダ"
                                                    IsReadOnly="True">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="TextWrapping" Value="Wrap" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn
                                                    Width="150"
                                                    MinWidth="150"
                                                    Binding="{Binding File_Date}"
                                                    CanUserReorder="False"
                                                    CanUserSort="True"
                                                    Header="ファイル日付"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="150"
                                                    MinWidth="150"
                                                    Binding="{Binding Regist_Date}"
                                                    CanUserSort="True"
                                                    Header="登録日"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="150"
                                                    MinWidth="150"
                                                    Binding="{Binding Last_Date, UpdateSourceTrigger=PropertyChanged}"
                                                    CanUserSort="True"
                                                    Header="最終アクセス日"
                                                    IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>

                                    <TabItem
                                        x:Name="TabBig10"
                                        Background="DarkBlue"
                                        Header="5x2"
                                        Tag="120x90x5x2">
                                        <ListView
                                            x:Name="BigList10"
                                            ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.IsDeferredScrollingEnabled="True"
                                            SelectionChanged="List_SelectionChanged"
                                            SelectionMode="Extended"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.ScrollUnit="Pixel"
                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <vwp:VirtualizingWrapPanel
                                                        Orientation="Horizontal"
                                                        StretchItems="True"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.ScrollUnit="Pixel"
                                                        VirtualizingPanel.VirtualizationMode="Recycling" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>

                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                    <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="BigList10Item_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </ListView.ItemContainerStyle>

                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <VirtualizingStackPanel
                                                        Orientation="Horizontal"
                                                        ScrollViewer.IsDeferredScrollingEnabled="true"
                                                        VirtualizingPanel.IsVirtualizing="True"
                                                        VirtualizingPanel.ScrollUnit="Pixel"
                                                        VirtualizingPanel.VirtualizationMode="Recycling">
                                                        <VirtualizingStackPanel
                                                            Orientation="Vertical"
                                                            VirtualizingPanel.IsVirtualizing="True"
                                                            VirtualizingPanel.ScrollUnit="Pixel"
                                                            VirtualizingPanel.VirtualizationMode="Recycling">

                                                            <view:BigTitleControl DataContext="{Binding}" />
                                                            <Label
                                                                Width="600"
                                                                Height="180"
                                                                MouseDoubleClick="PlayMovie_Click"
                                                                MouseDown="Label_MouseDown"
                                                                VirtualizingPanel.ScrollUnit="Pixel">
                                                                <Image
                                                                    ContextMenu="{StaticResource menuContext}"
                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                                    VirtualizingPanel.VirtualizationMode="Recycling">
                                                                    <Image.Source>
                                                                        <!--
                                                                            Source="{Binding ThumbPathBig10, Converter={StaticResource noLockImageConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                                        -->
                                                                        <c:ConverterBindableParameter
                                                                            Binding="{Binding ThumbPathBig10}"
                                                                            Converter="{StaticResource noLockImageConverter}"
                                                                            ConverterParameter="{Binding IsExists}" />
                                                                    </Image.Source>
                                                                </Image>
                                                            </Label>

                                                        </VirtualizingStackPanel>

                                                        <view:BigDetailControl DataContext="{Binding}" />

                                                    </VirtualizingStackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </TabItem>

                                </TabControl>

                            </avalonDock:LayoutDocument>
                            <!--  ドキュメント ★ここまで  -->
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutPanel>
                    <avalonDock:LayoutAnchorablePane x:Name="uxAnchorablePane2" DockHeight="240">

                        <!--  ツールウィンドウ  -->
                        <!--  何故かクローズ（非表示なんだけど）閉じて保存すると二度と表示されないのでクローズ禁止にした  -->
                        <avalonDock:LayoutAnchorable
                            x:Name="exDetail"
                            Title="詳細"
                            AutoHideHeight="200"
                            CanAutoHide="True"
                            CanClose="False"
                            CanDockAsTabbedDocument="False"
                            CanHide="False"
                            ContentId="ToolExtension">
                            <view:ExtDetail x:Name="viewExtDetail" Visibility="Hidden" />
                        </avalonDock:LayoutAnchorable>

                        <avalonDock:LayoutAnchorable
                            x:Name="exBookMark"
                            Title="ブックマーク"
                            AutoHideHeight="200"
                            CanAutoHide="True"
                            CanClose="False"
                            CanDockAsTabbedDocument="False"
                            CanHide="False"
                            ContentId="ToolBookmark">
                            <ListView
                                x:Name="BookmarkList"
                                ItemsSource="{Binding BookmarkRecs, UpdateSourceTrigger=PropertyChanged}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.IsDeferredScrollingEnabled="True"
                                SelectionMode="Extended"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling">

                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <vwp:VirtualizingWrapPanel
                                            Orientation="Horizontal"
                                            SpacingMode="BetweenItemsOnly"
                                            StretchItems="True"
                                            VirtualizingPanel.IsVirtualizing="True" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <view:Bookmark x:Name="viewBookmark" DataContext="{Binding}" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>

                            </ListView>

                        </avalonDock:LayoutAnchorable>
                        <!--  ツールウィンドウ  -->
                        <avalonDock:LayoutAnchorable
                            x:Name="TagBar"
                            Title="保存済み検索条件"
                            AutoHideHeight="200"
                            CanAutoHide="True"
                            CanClose="False"
                            CanDockAsTabbedDocument="False"
                            CanHide="False"
                            ContentId="ToolTagBar">
                            <TextBlock Margin="8" Text="保存済み検索条件は準備中です。" />
                        </avalonDock:LayoutAnchorable>

                        <avalonDock:LayoutAnchorable
                            x:Name="ThumbnailProgressTab"
                            Title="サムネイル進捗"
                            AutoHideHeight="200"
                            CanAutoHide="True"
                            CanClose="False"
                            CanDockAsTabbedDocument="False"
                            CanHide="False"
                            ContentId="ToolThumbnailProgress">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ScrollViewer
                                    Grid.Column="0"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="Bold" Text="基本情報" />
                                        <Separator Margin="0,4,0,8" />

                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Width="160" Text="作成済み / 総キュー" />
                                            <TextBlock Text="{Binding ThumbnailProgress.CreatedQueueText}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Width="160" Text="DB登録待ち / DB総数" />
                                            <TextBlock Text="{Binding ThumbnailProgress.DbPendingText}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Width="160" Text="現在 / 最大 / 論理コア" />
                                            <TextBlock Text="{Binding ThumbnailProgress.ThreadText}" />
                                        </DockPanel>

                                        <TextBlock
                                            Margin="0,12,0,0"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Text="設定" />
                                        <Separator Margin="0,4,0,8" />

                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock
                                                Width="160"
                                                VerticalAlignment="Center"
                                                Text="サムネイルを縮小"
                                                ToolTip="縮小する=WBのサムネサイズに準拠。縮小しない=1枚あたり上限320x240です。" />
                                            <CheckBox
                                                x:Name="ThumbnailProgressResizeThumbCheckBox"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding Source={x:Static prop:Settings.Default}, Path=IsResizeThumb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>

                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock
                                                Width="160"
                                                VerticalAlignment="Center"
                                                Text="GPUを使う"
                                                ToolTip="速度差は小さい場合がありますが、CPU負荷を下げたい時に有効です。" />
                                            <CheckBox
                                                x:Name="ThumbnailProgressGpuDecodeEnabled"
                                                VerticalAlignment="Center"
                                                Click="ThumbnailProgressGpuDecodeEnabled_Click"
                                                IsChecked="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailGpuDecodeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>

                                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                            <TextBlock Width="160" VerticalAlignment="Center" Text="並列作成数" />
                                            <TextBlock
                                                Width="36"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailParallelism}" />
                                            <Slider
                                                x:Name="sliderThumbnailProgressParallelism"
                                                Width="140"
                                                Maximum="24"
                                                Minimum="1"
                                                SmallChange="1"
                                                Style="{StaticResource MaterialDesignDiscreteSlider}"
                                                TickFrequency="1"
                                                ValueChanged="ThumbnailProgressParallelismSlider_ValueChanged"
                                                Value="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailParallelism, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                            <TextBlock
                                                Width="160"
                                                VerticalAlignment="Center"
                                                Text="小動画判定(MB)"
                                                ToolTip="この値以下の動画を優先レーンへ寄せます。" />
                                            <TextBlock
                                                Width="48"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailPriorityLaneMaxMb}" />
                                            <Slider
                                                x:Name="sliderThumbnailProgressPriorityLaneMaxMb"
                                                Width="140"
                                                Maximum="4096"
                                                Minimum="30"
                                                SmallChange="10"
                                                Style="{StaticResource MaterialDesignDiscreteSlider}"
                                                TickFrequency="10"
                                                ValueChanged="ThumbnailProgressPriorityLaneMaxMbSlider_ValueChanged"
                                                Value="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailPriorityLaneMaxMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                            <TextBlock
                                                Width="160"
                                                VerticalAlignment="Center"
                                                Text="巨大動画判定(GB)"
                                                ToolTip="この値以上の動画を低速レーンへ寄せます。" />
                                            <TextBlock
                                                Width="48"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailSlowLaneMinGb}" />
                                            <Slider
                                                x:Name="sliderThumbnailProgressSlowLaneMinGb"
                                                Width="140"
                                                Maximum="1024"
                                                Minimum="1"
                                                SmallChange="1"
                                                Style="{StaticResource MaterialDesignDiscreteSlider}"
                                                TickFrequency="1"
                                                ValueChanged="ThumbnailProgressSlowLaneMinGbSlider_ValueChanged"
                                                Value="{Binding Source={x:Static prop:Settings.Default}, Path=ThumbnailSlowLaneMinGb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                            <TextBlock Width="160" VerticalAlignment="Center" Text="プリセット" />
                                            <Button
                                                Width="56"
                                                Margin="0,0,8,0"
                                                Click="ThumbnailProgressPresetFastButton_Click"
                                                Content="速度"
                                                ToolTip="小動画優先 / 並列多め" />
                                            <Button
                                                Width="56"
                                                Margin="0,0,8,0"
                                                Click="ThumbnailProgressPresetNormalButton_Click"
                                                Content="普通"
                                                ToolTip="標準バランス" />
                                            <Button
                                                Width="56"
                                                Click="ThumbnailProgressPresetLowLoadButton_Click"
                                                Content="低負荷"
                                                ToolTip="巨大動画寄り / 並列少なめ" />
                                        </StackPanel>

                                        <TextBlock
                                            Margin="0,0,0,8"
                                            FontSize="12"
                                            Text="ショートカット: Ctrl + + で並列数を増加 / Ctrl + - で並列数を減少" />
                                    </StackPanel>
                                </ScrollViewer>

                                <ScrollViewer
                                    Grid.Column="2"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ThumbnailProgress.WorkerPanels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel IsItemsHost="True" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="230"
                                                    Margin="4"
                                                    Padding="6"
                                                    BorderBrush="#664A4A4A"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#00FFFFFF" />
                                                            <Setter Property="Opacity" Value="1.0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="False">
                                                                    <Setter Property="Background" Value="#22A0A0A0" />
                                                                    <Setter Property="Opacity" Value="0.70" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,2">
                                                            <TextBlock
                                                                FontSize="12"
                                                                FontWeight="Bold"
                                                                Text="{Binding WorkerLabel, Mode=OneWay}" />
                                                            <Border
                                                                DockPanel.Dock="Right"
                                                                Margin="6,0,0,0"
                                                                Padding="6,1"
                                                                Background="#33000000"
                                                                CornerRadius="3">
                                                                <TextBlock
                                                                    FontSize="10"
                                                                    Text="{Binding StatusText, Mode=OneWay}" />
                                                            </Border>
                                                        </DockPanel>
                                                        <TextBlock
                                                            Margin="0,2,0,6"
                                                            Text="{Binding MovieName, Mode=OneWay}"
                                                            TextTrimming="CharacterEllipsis"
                                                            ToolTip="{Binding MovieName, Mode=OneWay}" />
                                                        <Border BorderBrush="#44333333" BorderThickness="1">
                                                            <Image
                                                                Height="72"
                                                                Stretch="Uniform">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource thumbnailProgressPreviewConverter}" ConverterParameter="72">
                                                                        <Binding Mode="OneWay" Path="PreviewCacheKey" />
                                                                        <Binding Mode="OneWay" Path="PreviewRevision" />
                                                                        <Binding Mode="OneWay" Path="PreviewImagePath" />
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <materialDesign:DrawerHost IsLeftDrawerOpen="{Binding IsChecked, ElementName=MenuToggleButton}">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <DockPanel MinWidth="220">
                    <ToggleButton
                        Margin="16"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Top"
                        IsChecked="{Binding IsChecked, ElementName=MenuToggleButton, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignHamburgerToggleButton}" />

                    <VirtualizingStackPanel
                        Margin="16,4"
                        VirtualizingPanel.IsVirtualizing="true"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <Button
                            x:Name="BtnNew"
                            Margin="9,0,0,0"
                            HorizontalAlignment="Left"
                            Click="BtnNew_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="FolderAdd" />
                                <TextBlock Margin="10,0" Text="新規作成" />
                            </DockPanel>
                        </Button>

                        <Button
                            x:Name="BtnOpen"
                            Margin="9,0,0,0"
                            HorizontalAlignment="Left"
                            Click="BtnOpen_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="FolderOpen" />
                                <TextBlock Margin="10,0" Text="ファイルを開く" />
                            </DockPanel>
                        </Button>

                        <TreeView
                            x:Name="MenuRecent"
                            Margin="0,0,0,0"
                            ItemsSource="{Binding RecentTreeRoot, UpdateSourceTrigger=PropertyChanged}">

                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </TreeView.Resources>

                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:TreeSource}" ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}">
                                    <Button
                                        Margin="1,0,1,0"
                                        Padding="4,4,0,6"
                                        HorizontalAlignment="Left"
                                        Click="MenuRecentTree_Click"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Tag="{Binding Text}">
                                        <DockPanel>
                                            <materialDesign:PackIcon VerticalAlignment="Center" Kind="File" />
                                            <TextBlock
                                                Margin="10,4,10,2"
                                                VerticalAlignment="Center"
                                                Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text}" />
                                        </DockPanel>
                                    </Button>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>

                        </TreeView>

                        <TreeView
                            x:Name="MenuConfig"
                            ItemsSource="{Binding ConfigTreeRoot, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignTreeView}">

                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </TreeView.Resources>

                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:TreeSource}" ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}">
                                    <Button
                                        Margin="1,0,1,0"
                                        Padding="4,4,0,6"
                                        HorizontalAlignment="Left"
                                        Click="MenuBtnSettings_Click"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Tag="{Binding Text}">
                                        <DockPanel>
                                            <materialDesign:PackIcon VerticalAlignment="Center" Kind="{Binding IconKind}" />
                                            <TextBlock
                                                Margin="10,4,10,2"
                                                VerticalAlignment="Center"
                                                Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text}" />
                                        </DockPanel>
                                    </Button>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <TreeView
                            x:Name="MenuTool"
                            ItemsSource="{Binding ToolTreeRoot, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignTreeView}">

                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </TreeView.Resources>

                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:TreeSource}" ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}">
                                    <Button
                                        Margin="1,0,1,0"
                                        Padding="4,4,0,6"
                                        HorizontalAlignment="Left"
                                        Click="MenuBtnTool_Click"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Tag="{Binding Text}">
                                        <DockPanel>
                                            <materialDesign:PackIcon VerticalAlignment="Center" Kind="{Binding IconKind}" />
                                            <TextBlock
                                                Margin="10,4,10,2"
                                                VerticalAlignment="Center"
                                                Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text}" />
                                        </DockPanel>
                                    </Button>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <Button
                            x:Name="BtnExit"
                            Margin="9,0,0,0"
                            HorizontalAlignment="Left"
                            Click="BtnExit_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <DockPanel>
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="ExitToApp" />
                                <TextBlock
                                    Margin="10,0"
                                    VerticalAlignment="Center"
                                    Text="終了" />
                            </DockPanel>
                        </Button>

                    </VirtualizingStackPanel>
                </DockPanel>
            </materialDesign:DrawerHost.LeftDrawerContent>

            <materialDesign:ColorZone Padding="16" Mode="PrimaryDark">
                <DockPanel>
                    <VirtualizingStackPanel
                        Orientation="Horizontal"
                        VirtualizingPanel.IsVirtualizing="true"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <ToggleButton
                            x:Name="MenuToggleButton"
                            AutomationProperties.Name="HamburgerToggleButton"
                            Style="{DynamicResource MaterialDesignHamburgerToggleButton}" />

                        <ComboBox
                            x:Name="SearchBox"
                            Width="326"
                            Height="Auto"
                            Margin="30,4,16,4"
                            Padding="4,4,0,4"
                            HorizontalContentAlignment="Stretch"
                            materialDesign:HintAssist.Hint="検索キーワードを入れて下さい。"
                            materialDesign:HintAssist.IsFloating="True"
                            materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                            materialDesign:TextFieldAssist.HasClearButton="True"
                            materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                            materialDesign:TextFieldAssist.TextFieldCornerRadius="3"
                            materialDesign:TextFieldAssist.UnderlineBrush="Black"
                            Background="White"
                            Cursor=""
                            DisplayMemberPath="Find_Text"
                            DockPanel.Dock="Top"
                            DropDownClosed="SearchBox_DropDownClosed"
                            FontSize="14"
                            Foreground="Black"
                            IsEditable="True"
                            ItemsSource="{Binding HistoryRecs}"
                            LostFocus="SearchBox_LostFocus"
                            PreviewKeyDown="SearchBox_PreviewKeyDown"
                            SelectedValue="{Binding DbInfo.SearchKeyword}"
                            SelectedValuePath="Find_Text"
                            SelectionChanged="SearchBox_SelectionChanged"
                            SelectiveScrollingGrid.SelectiveScrollingOrientation="None"
                            Text="{Binding DbInfo.SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                            TextBoxBase.TextChanged="SearchBox_TextChanged">

                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <EventSetter Event="MouseMove" Handler="SearchBoxItem_MouseMove" />
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchBoxItem_PreviewMouseLeftButtonDown" />
                                    <Style.Triggers>
                                        <!--  選択時の反転表示  -->
                                        <Trigger Property="IsSelected" Value="True" />
                                    </Style.Triggers>

                                </Style>
                            </ComboBox.ItemContainerStyle>

                        </ComboBox>
                        <Button
                            x:Name="ReloadButton"
                            Click="ReloadButton_Click"
                            Content="Reload"
                            IsDefault="True" />
                        <Label
                            Margin="30,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="ソート順："
                            Foreground="White" />
                        <ComboBox
                            x:Name="ComboSort"
                            Width="200"
                            Margin="4,0,4,0"
                            Background="White"
                            Style="{x:Null}"
                            DisplayMemberPath="Name"
                            Foreground="Black"
                            ItemsSource="{Binding SortLists}"
                            SelectedValue="{Binding DbInfo.Sort}"
                            SelectedValuePath="Id"
                            SelectionChanged="ComboSort_SelectionChanged" />
                        <Label
                            Margin="30,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding DbInfo.SearchCount, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="White" />
                        <Label
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="/"
                            Foreground="White" />
                        <Label
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{Binding MovieRecs.Count, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="White" />
                        <Label
                            Margin="20,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="登録待ち:"
                            Foreground="#FFF3C76B" />
                        <Label
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{Binding PendingMovieRecs.Count, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="#FFF3C76B" />
                        <Label
                            x:Name="lbDbFullPath"
                            Margin="20,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{Binding DbInfo.DBFullPath, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="White" />
                    </VirtualizingStackPanel>
                </DockPanel>
            </materialDesign:ColorZone>
        </materialDesign:DrawerHost>

        <notifications:NotificationArea x:Name="ProgressArea" Position="BottomRight" />

        <StackPanel
            x:Name="PlayerArea"
            Width="Auto"
            Height="Auto"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Vertical"
            Visibility="Collapsed">
            <StackPanel.Effect>
                <DropShadowEffect
                    BlurRadius="2"
                    RenderingBias="Performance"
                    ShadowDepth="10"
                    Color="DarkGoldenrod" />
            </StackPanel.Effect>
            <MediaElement
                x:Name="uxVideoPlayer"
                Grid.Row="0"
                Width="900"
                Height="Auto"
                LoadedBehavior="Manual"
                MediaOpened="UxVideoPlayer_MediaOpened"
                PreviewMouseDown="UxVideoPlayer_PreviewMouseDown"
                ScrubbingEnabled="true"
                Stretch="Uniform"
                UnloadedBehavior="Stop" />
            <StackPanel
                x:Name="PlayerController"
                Grid.Row="1"
                Width="Auto"
                Background="Black"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <RepeatButton
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="FR_Click"
                    Content="{materialDesign:PackIcon Kind=Rewind}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="戻す" />
                <Button
                    x:Name="PlayButton"
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="Start_Click"
                    Content="{materialDesign:PackIcon Kind=Play}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="再生" />
                <RepeatButton
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="FF_Click"
                    Content="{materialDesign:PackIcon Kind=FastForward}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="送る" />
                <Button
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="Pause_Click"
                    Content="{materialDesign:PackIcon Kind=PauseBox}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="一時停止" />
                <Button
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="Capture_Click"
                    Content="{materialDesign:PackIcon Kind=Camera}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="サムネイルの取得" />
                <Button
                    Margin="5"
                    Background="{x:Null}"
                    BorderThickness="0"
                    Click="AddBookmark_Click"
                    Content="{materialDesign:PackIcon Kind=BookmarkAdd}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="ブックマークの追加" />
                <Slider
                    x:Name="uxTimeSlider"
                    Width="300"
                    Height="20"
                    Margin="5"
                    IsSnapToTickEnabled="True"
                    LostMouseCapture="UxTimeSlider_LostMouseCapture"
                    PreviewMouseLeftButtonDown="UxTimeSlider_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="UxTimeSlider_PreviewMouseLeftButtonUp"
                    SmallChange="2000"
                    ToolTip="再生位置"
                    ValueChanged="UxTimeSlider_ValueChanged"
                    Value="0" />
                <TextBlock
                    x:Name="uxTime"
                    Width="Auto"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    ToolTip="再生時刻" />
                <Slider
                    x:Name="uxVolumeSlider"
                    Width="50"
                    Height="20"
                    MinWidth="50"
                    Margin="20,0,0,0"
                    Maximum="1"
                    Minimum="0"
                    ToolTip="音量調整"
                    ValueChanged="UxVolumeSlider_ValueChanged"
                    Value="0.5" />
                <TextBlock
                    x:Name="uxVolume"
                    Width="40"
                    MinWidth="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    TextAlignment="Right"
                    ToolTip="音量" />
                <Button
                    Width="30"
                    Height="30"
                    Margin="20,0,0,0"
                    Padding="0"
                    Background="{x:Null}"
                    BorderThickness="1"
                    Click="Stop_Click"
                    Content="{materialDesign:PackIcon Kind=Close}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="終了" />
            </StackPanel>
        </StackPanel>
    </Grid>

</Window>
