<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock">
  <!-- OS連動テーマ: MDIX のテーマリソースに追従する -->
  <avalonDock:Vs2013DarkTheme x:Key="AvalonDockTheme" />
  <SolidColorBrush x:Key="TagBorderBackground" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="UpperTabBackground" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="ThumbImageBackground" Color="Transparent" />
  <SolidColorBrush x:Key="HeaderForeground" Color="{DynamicResource {x:Static SystemColors.ControlTextColorKey}}" />
  <SolidColorBrush x:Key="SearchBoxBackground" Color="Transparent" />
  <SolidColorBrush x:Key="SearchBoxForeground" Color="{DynamicResource {x:Static SystemColors.ControlTextColorKey}}" />
  <SolidColorBrush x:Key="SortComboBackground" Color="Transparent" />
  <SolidColorBrush x:Key="SortComboForeground" Color="{DynamicResource {x:Static SystemColors.ControlTextColorKey}}" />
  <x:Null x:Key="MainHeaderBackground" />
  <x:Null x:Key="MainHeaderSearchBoxBackground" />
  <x:Null x:Key="MainHeaderSortComboBackground" />
  <SolidColorBrush x:Key="PlayerControllerBackground" Color="{DynamicResource {x:Static SystemColors.ControlDarkColorKey}}" />
  <Color x:Key="PlayerShadowColor">DarkGoldenrod</Color>
</ResourceDictionary>
