<UserControl
    x:Class="IndigoMovieManager.UpperTabs.DuplicateVideos.DuplicateVideosTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- サムネは既存の軽量読み込み経路をそのまま使う。 -->
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,6"
            Padding="8,6"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button
                    x:Name="DetectButton"
                    Click="DetectButton_Click"
                    Content="検出" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="左リスト順" />
                <ComboBox
                    x:Name="GroupSortComboBox"
                    Width="120"
                    Margin="4,0,0,0"
                    SelectionChanged="GroupSortComboBox_SelectionChanged" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="重複ハッシュ数" />
                <TextBlock
                    x:Name="GroupCountTextBlock"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="0" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="選択中重複数" />
                <TextBlock
                    x:Name="SelectedCountTextBlock"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="0" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="選択中ハッシュ" />
                <TextBlock
                    x:Name="SelectedHashTextBlock"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="-" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid
                x:Name="DuplicateGroupDataGrid"
                Grid.Column="0"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeRows="False"
                ContextMenu="{DynamicResource menuContext}"
                IsReadOnly="True"
                SelectionChanged="DuplicateGroupDataGrid_SelectionChanged"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="176" Header="Grid">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Width="160"
                                    Height="120"
                                    Margin="4"
                                    Background="{DynamicResource ThumbImageBackground}">
                                    <Image
                                        Stretch="Uniform"
                                        Source="{Binding RepresentativeThumbnailPath, Converter={StaticResource noLockImageConverter}}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="*"
                        MinWidth="120"
                        Binding="{Binding RepresentativeMovieName}"
                        Header="動画名" />
                    <DataGridTextColumn
                        Width="68"
                        MinWidth="56"
                        Binding="{Binding DuplicateCount}"
                        Header="重複数" />
                    <DataGridTextColumn
                        Width="92"
                        MinWidth="84"
                        Binding="{Binding MaxMovieSizeText}"
                        Header="最大サイズ" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource MaterialDesignDivider}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns" />

            <DataGrid
                x:Name="DuplicateDetailDataGrid"
                Grid.Column="2"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeRows="False"
                CellEditEnding="DuplicateDetailDataGrid_CellEditEnding"
                ContextMenu="{DynamicResource menuContext}"
                IsReadOnly="False"
                MouseDoubleClick="DuplicateDetailDataGrid_MouseDoubleClick"
                SelectionChanged="DuplicateDetailDataGrid_SelectionChanged"
                SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="176" Header="サムネ">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Width="160"
                                    Height="120"
                                    Margin="4"
                                    Background="{DynamicResource ThumbImageBackground}">
                                    <Image
                                        Stretch="Uniform"
                                        Source="{Binding ThumbnailPath, Converter={StaticResource noLockImageConverter}}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="200"
                        MinWidth="160"
                        Binding="{Binding MovieName}"
                        Header="動画名"
                        IsReadOnly="False" />
                    <DataGridTextColumn
                        Width="88"
                        MinWidth="72"
                        Binding="{Binding ProbText}"
                        Header="prob"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="88"
                        MinWidth="80"
                        Binding="{Binding MovieSizeText}"
                        Header="サイズ"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="96"
                        MinWidth="88"
                        Binding="{Binding SizeCompareText}"
                        Header="サイズ差"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="150"
                        MinWidth="150"
                        Binding="{Binding FileDateText}"
                        Header="ファイル日付"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="*"
                        MinWidth="320"
                        Binding="{Binding MoviePath}"
                        Header="動画パス"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
