<UserControl
    x:Class="IndigoMovieManager.UpperTabs.Rescue.RescueTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource BottomTabRootUserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 単体で開いても MainWindow の Resource に依存せず初期化できるようにする。 -->
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="4" />
            <RowDefinition Height="142" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Text="対象タブ" />
                <ComboBox
                    x:Name="TargetTabComboBox"
                    Width="96"
                    Height="22"
                    DisplayMemberPath="DisplayName" />
                <Button
                    Click="RefreshButton_Click"
                    Content="更新"
                    Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                <Button
                    Margin="0"
                    Click="BulkNormalRetryButton_Click"
                    Content="一括通常再試行"
                    Style="{StaticResource HighDensityBottomTabButtonStyle}" />
            </StackPanel>

            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="10"
                Foreground="{DynamicResource MaterialDesignBodySecondary}"
                Text="一覧再集計は手動更新、作成済みサムネ差し替えは即時反映します。" />
        </Grid>

        <DataGrid
            x:Name="RescueListDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            CanUserResizeRows="False"
            CellStyle="{StaticResource HighDensityBottomTabDataGridCellStyle}"
            ColumnHeaderStyle="{StaticResource HighDensityBottomTabDataGridColumnHeaderStyle}"
            ContextMenu="{DynamicResource menuContext}"
            Foreground="{DynamicResource MaterialDesignBody}"
            IsReadOnly="True"
            MouseDoubleClick="RescueListDataGrid_MouseDoubleClick"
            RowStyle="{StaticResource HighDensityBottomTabDataGridRowStyle}"
            SelectionChanged="RescueListDataGrid_SelectionChanged"
            SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTemplateColumn
                    Width="34"
                    Header="サムネ">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Width="24"
                                Height="18"
                                Background="{DynamicResource ThumbImageBackground}">
                                <Image
                                    Stretch="Uniform"
                                    Source="{Binding ThumbnailPath, Converter={StaticResource noLockImageConverter}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="164"
                    MinWidth="120"
                    Binding="{Binding MovieName}"
                    Header="動画名"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="68"
                    MinWidth="64"
                    Binding="{Binding MovieSizeText}"
                    Header="サイズ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="56"
                    MinWidth="52"
                    Binding="{Binding MovieLengthText}"
                    Header="長さ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="124"
                    MinWidth="124"
                    Binding="{Binding FileDateText}"
                    Header="ファイル日付"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="66"
                    MinWidth="60"
                    Binding="{Binding FailedTabsText}"
                    Header="失敗タブ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="66"
                    MinWidth="60"
                    Binding="{Binding ProgressStatusText}"
                    Header="状態"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="172"
                    MinWidth="132"
                    Binding="{Binding ProgressDetailText}"
                    Header="理由"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="*"
                    MinWidth="180"
                    Binding="{Binding MoviePath}"
                    Header="動画パス"
                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource MaterialDesignDivider}"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Rows" />

        <Border
            Grid.Row="3"
            Padding="4,3"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel
                    Grid.Row="0"
                    ItemHeight="18"
                    MinHeight="18">
                    <TextBlock
                        Margin="0"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Text="救済履歴" />
                </WrapPanel>

                <Grid Grid.Row="1" Margin="0,3,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="HistoryTargetTextBlock"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Foreground="{DynamicResource MaterialDesignBodySecondary}"
                            Text="動画を選ぶと履歴を表示します。"
                            TextTrimming="CharacterEllipsis" />

                        <Button
                            x:Name="AutogenButton"
                            Grid.Column="1"
                            Margin="0"
                            Click="SelectedAutogenButton_Click"
                            Content="autogen"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            x:Name="FfmpegButton"
                            Grid.Column="2"
                            Margin="0"
                            Click="SelectedFfmpegButton_Click"
                            Content="ffmpeg"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            x:Name="FfmediaToolkitButton"
                            Grid.Column="3"
                            Margin="0"
                            Click="SelectedFfmediaToolkitButton_Click"
                            Content="ffmediatoolkit"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            x:Name="OpenCvButton"
                            Grid.Column="4"
                            Margin="0"
                            Click="SelectedOpenCvButton_Click"
                            Content="opencv"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            Grid.Column="5"
                            Margin="0"
                            Click="SelectedIndexRepairButton_Click"
                            Content="インデックス再構築"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            Grid.Column="6"
                            Margin="0"
                            Click="SelectedBlackConfirmButton_Click"
                            Content="黒確定"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            Grid.Column="7"
                            Margin="0"
                            Click="SelectedBlackLiteRetryButton_Click"
                            Content="簡易黒背景対策"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                        <Button
                            Grid.Column="8"
                            Margin="0"
                            Click="SelectedBlackDeepRetryButton_Click"
                            Content="徹底黒背景対策(長時間)"
                            Style="{StaticResource HighDensityBottomTabButtonStyle}" />
                    </Grid>

                    <DataGrid
                        x:Name="RescueHistoryDataGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeRows="False"
                        CellStyle="{StaticResource HighDensityBottomTabDataGridCellStyle}"
                        ColumnHeaderStyle="{StaticResource HighDensityBottomTabDataGridColumnHeaderStyle}"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        RowStyle="{StaticResource HighDensityBottomTabDataGridRowStyle}"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="108"
                                MinWidth="102"
                                Binding="{Binding TimestampText}"
                                Header="時刻"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="52"
                                MinWidth="48"
                                Binding="{Binding LaneText}"
                                Header="経路"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="88"
                                MinWidth="76"
                                Binding="{Binding ActionText}"
                                Header="処理"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="52"
                                MinWidth="48"
                                Binding="{Binding ResultText}"
                                Header="結果"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="38"
                                MinWidth="34"
                                Binding="{Binding AttemptText}"
                                Header="回"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="84"
                                MinWidth="72"
                                Binding="{Binding EngineText}"
                                Header="エンジン"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="*"
                                MinWidth="140"
                                Binding="{Binding DetailText}"
                                Header="詳細"
                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock
                        x:Name="HistoryEmptyTextBlock"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="{DynamicResource MaterialDesignBodySecondary}"
                        IsHitTestVisible="False"
                        Text="履歴はまだありません。"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
