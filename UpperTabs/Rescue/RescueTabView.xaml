<UserControl
    x:Class="IndigoMovieManager.UpperTabs.Rescue.RescueTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 単体で開いても MainWindow の Resource に依存せず初期化できるようにする。 -->
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,6"
            Padding="8,6"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="対象タブ" />
                <ComboBox
                    x:Name="TargetTabComboBox"
                    Width="120"
                    DisplayMemberPath="DisplayName" />
                <Button
                    Margin="8,0,0,0"
                    Click="RefreshButton_Click"
                    Content="更新" />
            </StackPanel>
        </Border>

        <DataGrid
            x:Name="RescueListDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            CanUserResizeRows="False"
            ContextMenu="{DynamicResource menuContext}"
            IsReadOnly="True"
            MouseDoubleClick="RescueListDataGrid_MouseDoubleClick"
            SelectionChanged="RescueListDataGrid_SelectionChanged"
            SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTemplateColumn
                    Width="Auto"
                    Header="サムネ">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Width="{Binding ThumbnailWidth}"
                                Height="{Binding ThumbnailHeight}"
                                Background="{DynamicResource ThumbImageBackground}">
                                <Image
                                    Stretch="Uniform"
                                    Source="{Binding ThumbnailPath, Converter={StaticResource noLockImageConverter}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="220"
                    MinWidth="180"
                    Binding="{Binding MovieName}"
                    Header="動画名"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="88"
                    MinWidth="80"
                    Binding="{Binding MovieSizeText}"
                    Header="サイズ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="72"
                    MinWidth="64"
                    Binding="{Binding MovieLengthText}"
                    Header="長さ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="60"
                    MinWidth="56"
                    Binding="{Binding ScoreText}"
                    Header="スコア"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="150"
                    MinWidth="150"
                    Binding="{Binding FileDateText}"
                    Header="ファイル日付"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="88"
                    MinWidth="80"
                    Binding="{Binding FailedTabsText}"
                    Header="失敗タブ"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="92"
                    MinWidth="88"
                    Binding="{Binding ProgressStatusText}"
                    Header="状態"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="200"
                    MinWidth="160"
                    Binding="{Binding ProgressDetailText}"
                    Header="理由"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="*"
                    MinWidth="260"
                    Binding="{Binding MoviePath}"
                    Header="動画パス"
                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
