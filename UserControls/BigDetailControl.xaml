<UserControl
    x:Class="IndigoMovieManager.UserControls.BigDetailControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:indigomoviemanager="clr-namespace:IndigoMovieManager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=indigomoviemanager:MovieRecords}"
    d:DesignHeight="150"
    d:DesignWidth="170"
    Foreground="{DynamicResource UpperTabPanelForegroundBrush}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:FileDatePartConverter x:Key="FileDatePartConverter" />
        <c:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Margin="0,26,0,0" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0">
            <Run Text="スコア：" />
            <Run Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" />
        </TextBlock>

        <TextBlock
            Grid.Row="1"
            Text="{Binding Movie_Length, Converter={StaticResource FileDatePartConverter}, ConverterParameter=Duration}"
            TextWrapping="NoWrap" />

        <TextBlock
            Grid.Row="2"
            Text="{Binding Movie_Size, Converter={StaticResource FileSizeConverter}}"
            TextWrapping="NoWrap" />

        <TextBlock
            Grid.Row="4"
            Text="日時：" />

        <TextBlock
            Grid.Row="5"
            Text="{Binding File_Date, Converter={StaticResource FileDatePartConverter}, ConverterParameter=Date}"
            TextWrapping="NoWrap" />

        <TextBlock
            Grid.Row="6"
            Text="{Binding File_Date, Converter={StaticResource FileDatePartConverter}, ConverterParameter=Time}"
            TextWrapping="NoWrap" />
    </Grid>
</UserControl>
