<UserControl
    x:Name="ExtDetailRoot"
    x:Class="IndigoMovieManager.UserControls.ExtDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:indigomoviemanager="clr-namespace:IndigoMovieManager"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:IndigoMovieManager.UserControls"
    d:DataContext="{d:DesignInstance Type=indigomoviemanager:MovieRecords}"
    d:DesignHeight="250"
    d:DesignWidth="740"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:FileSizeConverter x:Key="FileSizeConverter" />
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
        <Style
            x:Key="DetailThumbnailModeComboBoxStyle"
            BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
            TargetType="ComboBox">
            <Setter Property="Padding" Value="4,2,24,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Hidden" />
            <Setter Property="materialDesign:TextFieldAssist.HasOutlinedTextField" Value="False" />
            <Setter Property="materialDesign:HintAssist.Hint" Value="{x:Null}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Margin="0,0,0,6"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Disabled"
            CanContentScroll="False">
            <StackPanel
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <ComboBox
                    x:Name="DetailThumbnailModeComboBox"
                    MinWidth="170"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    SelectionChanged="DetailThumbnailModeComboBox_SelectionChanged"
                    Style="{StaticResource DetailThumbnailModeComboBoxStyle}">
                    <ComboBoxItem
                        Tag="Grid"
                        Content="Grid" />
                    <ComboBoxItem
                        Tag="Small"
                        Content="Small" />
                    <ComboBoxItem
                        Tag="Big"
                        Content="Big" />
                    <ComboBoxItem
                        Tag="List"
                        Content="List" />
                    <ComboBoxItem
                        Tag="FiveByTwo"
                        Content="5x2" />
                    <ComboBoxItem
                        Tag="WhiteBrowser"
                        Content="WhiteBrowser 160x90" />
                </ComboBox>

                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="18">
                    <Hyperlink
                        x:Name="FileNameLink"
                        Background="Transparent"
                        Hyperlink.Click="FileNameLink_Click"
                        NavigateUri="{Binding Movie_Body}">
                        <Run Text="{Binding Movie_Body}" />
                    </Hyperlink>
                    <Hyperlink
                        x:Name="Ext"
                        Background="Transparent"
                        Hyperlink.Click="Ext_Click"
                        NavigateUri="{Binding Ext}">
                        <Run Text="{Binding Ext}" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="15">
                    <Hyperlink
                        Background="Transparent"
                        Hyperlink.Click="Hyperlink_Click"
                        NavigateUri="{Binding Dir, FallbackValue='C:\\'}">
                        <Run Text="{Binding Dir}" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding Movie_Size, Converter={StaticResource FileSizeConverter}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text=" / " />
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding Movie_Length}" />
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding Container}" />
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding Video}" />
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding Audio}" />
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{Binding File_Date}" />

                <ItemsControl
                    x:Name="ExtDetailTags"
                    Margin="0,0,6,0"
                    ItemsSource="{Binding Tag, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.IsDeferredScrollingEnabled="True"
                    VirtualizingPanel.IsContainerVirtualizable="True"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <view:TagControl DataContext="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border
            x:Name="LabelExtDetail"
            Grid.Row="1"
            Background="Transparent"
            MouseLeftButtonDown="LabelExtDetail_MouseLeftButtonDown">
            <Image
                x:Name="DetailThumbnailImage"
                d:Source="../Images/errorGrid.jpg"
                ContextMenu="{DynamicResource menuContext}"
                HorizontalAlignment="Stretch"
                Stretch="Uniform"
                VerticalAlignment="Stretch"
                ContextMenuOpening="DetailThumbnailImage_ContextMenuOpening"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <Image.Source>
                    <c:ConverterBindableParameter
                        Binding="{Binding ThumbDetail}"
                        Converter="{StaticResource noLockImageConverter}"
                        ConverterParameter="{Binding DetailThumbnailDecodePixelHeight, ElementName=ExtDetailRoot}" />
                </Image.Source>
            </Image>
        </Border>
    </Grid>
</UserControl>
