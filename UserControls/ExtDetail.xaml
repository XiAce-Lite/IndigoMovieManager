<UserControl
    x:Class="IndigoMovieManager.UserControls.ExtDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:indigomoviemanager="clr-namespace:IndigoMovieManager"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:IndigoMovieManager.UserControls"
    d:DataContext="{d:DesignInstance Type=indigomoviemanager:MovieRecords}"
    d:DesignHeight="250"
    d:DesignWidth="740"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:FileSizeConverter x:Key="FileSizeConverter" />
        <c:NoLockImageConverter x:Key="noLockImageConverter" />
        <Style
            x:Key="DetailThumbnailModeComboBoxStyle"
            BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
            TargetType="ComboBox">
            <Setter Property="Padding" Value="4,2,24,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Hidden" />
            <Setter Property="materialDesign:TextFieldAssist.HasOutlinedTextField" Value="False" />
            <Setter Property="materialDesign:HintAssist.Hint" Value="{x:Null}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Column="0"
            HorizontalAlignment="Left"
            Orientation="Vertical"
            ScrollViewer.IsDeferredScrollingEnabled="true">
            <Label x:Name="LabelExtDetail"
                Width="160"
                Height="120"
                HorizontalAlignment="Left"
                MouseDoubleClick="Label_MouseDoubleClick">
                <Image
                    d:Source="../Images/errorGrid.jpg"
                    ContextMenu="{DynamicResource menuContext}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <Image.Source>
                        <c:ConverterBindableParameter
                            Binding="{Binding ThumbDetail}"
                            Converter="{StaticResource noLockImageConverter}"
                            ConverterParameter="{Binding IsExists}" />
                    </Image.Source>
                </Image>
            </Label>
            <ComboBox
                x:Name="DetailThumbnailModeComboBox"
                MinWidth="180"
                Margin="0,6,0,0"
                HorizontalAlignment="Left"
                HorizontalContentAlignment="Left"
                SelectionChanged="DetailThumbnailModeComboBox_SelectionChanged"
                Style="{StaticResource DetailThumbnailModeComboBoxStyle}">
                <ComboBoxItem
                    Tag="Small"
                    Content="小 120x90 (3x1)" />
                <ComboBoxItem
                    Tag="Big"
                    Content="大 200x150 (3x1)" />
                <ComboBoxItem
                    Tag="Grid"
                    Content="Grid 160x120 (1x1)" />
                <ComboBoxItem
                    Tag="List"
                    Content="List 56x42 (5x1)" />
                <ComboBoxItem
                    Tag="Big10"
                    Content="Big10 120x90 (5x2)" />
                <ComboBoxItem
                    Tag="Standard"
                    Content="標準 160x120 (1x1)" />
                <ComboBoxItem
                    Tag="WhiteBrowserCompatible"
                    Content="WhiteBrowser互換 120x90 (1x1)" />
            </ComboBox>
        </StackPanel>

        <VirtualizingStackPanel
            Grid.Column="1"
            Width="Auto"
            Margin="10,3,3,3"
            Orientation="Vertical"
            VirtualizingPanel.IsVirtualizing="true"
            VirtualizingPanel.VirtualizationMode="Recycling">

            <VirtualizingStackPanel
                Orientation="Horizontal"
                VirtualizingPanel.IsVirtualizing="true"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <Label
                    Width="Auto"
                    Margin="0,4,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    FontSize="18">

                    <Hyperlink
                        x:Name="FileNameLink"
                        Background="Transparent"
                        Hyperlink.Click="FileNameLink_Click"
                        NavigateUri="{Binding Movie_Body}">
                        <TextBlock d:Text="ダミーファイル" Text="{Binding Movie_Body, UpdateSourceTrigger=PropertyChanged}" />
                    </Hyperlink>
                </Label>

                <Label
                    Width="Auto"
                    Margin="4,4,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    FontSize="18">

                    <Hyperlink
                        x:Name="Ext"
                        Background="Transparent"
                        Hyperlink.Click="Ext_Click"
                        NavigateUri="{Binding Ext}">
                        <TextBlock d:Text=".mp4" Text="{Binding Ext, UpdateSourceTrigger=PropertyChanged}" />
                    </Hyperlink>
                </Label>

            </VirtualizingStackPanel>
            <Label
                Width="Auto"
                Margin="0,4,0,0"
                Padding="0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                FontSize="16">

                <Hyperlink
                    Background="Transparent"
                    Hyperlink.Click="Hyperlink_Click"
                    NavigateUri="{Binding Dir, FallbackValue='C:\\'}">
                    <TextBlock d:Text="C:\xxxxx\xxxxx\xxxxx" Text="{Binding Dir, UpdateSourceTrigger=PropertyChanged}" />
                </Hyperlink>
            </Label>

            <ItemsControl
                x:Name="ExtDetailTags"
                Height="Auto"
                Margin="0,4,0,6"
                d:Height="50"
                ItemsSource="{Binding Tag, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.IsDeferredScrollingEnabled="True"
                VirtualizingPanel.IsContainerVirtualizable="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <view:TagControl DataContext="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel
                            Width="Auto"
                            Height="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <VirtualizingStackPanel
                Margin="0,4,0,0"
                Orientation="Horizontal"
                VirtualizingPanel.IsVirtualizing="true"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <TextBlock
                    Padding="0"
                    d:Text="99,99GB"
                    FontSize="12"
                    Text="{Binding Movie_Size, Converter={StaticResource FileSizeConverter}}" />
                <TextBlock
                    Padding="0"
                    FontSize="12"
                    Text=" / " />
                <TextBlock
                    Padding="0"
                    d:Text="XX:XX:XX"
                    FontSize="12"
                    Text="{Binding Movie_Length}" />

            </VirtualizingStackPanel>

            <TextBlock
                Margin="0,0,0,0"
                Padding="0"
                d:Text="MP4"
                FontSize="12"
                Text="{Binding Container}" />
            <TextBlock
                Padding="0"
                d:Text="1980x1024 xxx xxxx"
                FontSize="12"
                Text="{Binding Video}" />
            <TextBlock
                Padding="0"
                d:Text="aac"
                FontSize="12"
                Text="{Binding Audio}" />
            <TextBlock
                Padding="0"
                d:Text="2023/01/01 00:00:00"
                FontSize="12"
                Text="{Binding File_Date}" />

        </VirtualizingStackPanel>
    </Grid>
</UserControl>
