<UserControl
    x:Class="IndigoMovieManager.UserControls.SmallDetailControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:IndigoMovieManager.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:indigomoviemanager="clr-namespace:IndigoMovieManager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=indigomoviemanager:MovieRecords}"
    d:DesignHeight="72"
    d:DesignWidth="148"
    VerticalAlignment="Top"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Width="148" Margin="3,0,0,0" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" VerticalAlignment="Top" TextTrimming="CharacterEllipsis" ToolTip="{Binding Movie_Path}">
            <Run Text="{Binding Movie_Body, UpdateSourceTrigger=PropertyChanged}" />
            <Run Text="{Binding Ext, UpdateSourceTrigger=PropertyChanged}" />
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock Padding="0" Text="スコア：" />
            <TextBlock
                Padding="0"
                d:Text="9999"
                Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <TextBlock
            Grid.Row="2"
            Padding="0"
            d:Text="2026-03-17 12:34:56"
            Text="{Binding File_Date, UpdateSourceTrigger=PropertyChanged}"
            TextWrapping="NoWrap" />

        <TextBlock
            Grid.Row="3"
            Padding="0"
            d:Text="9999"
            Text="{Binding Movie_Size, Converter={StaticResource FileSizeConverter}}" />
    </Grid>
</UserControl>
