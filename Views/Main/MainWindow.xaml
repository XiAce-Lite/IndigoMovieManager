              ItemsSource="{Binding HistoryRecs}"
              LostFocus="SearchBox_LostFocus"
              PreviewKeyDown="SearchBox_PreviewKeyDown"
              SelectedValue="{Binding DbInfo.SearchKeyword}"
              SelectedValuePath="Find_Text"
              SelectionChanged="SearchBox_SelectionChanged"
              SelectiveScrollingGrid.SelectiveScrollingOrientation="None"
              Style="{StaticResource MainHeaderSearchBoxStyle}"
              Text="{Binding DbInfo.SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
              TextBoxBase.TextChanged="SearchBox_TextChanged"
            >
              <ComboBox.ItemContainerStyle>
                <Style BasedOn="{StaticResource MaterialDesignComboBoxItemStyle}" TargetType="ComboBoxItem">
                  <!--  内容更新時のバインドエラー回避のおまじない。  -->
                  <Setter Property="HorizontalAlignment" Value="Stretch" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                  <Setter Property="VerticalContentAlignment" Value="Stretch" />
                  <EventSetter Event="MouseMove" Handler="SearchBoxItem_MouseMove" />
                  <EventSetter
                    Event="PreviewMouseLeftButtonDown"
                    Handler="SearchBoxItem_PreviewMouseLeftButtonDown"
                  />
                  <Style.Triggers>
                    <!--  選択時の反転表示  -->
                    <Trigger Property="IsSelected" Value="True" />
                  </Style.Triggers>
                </Style>
              </ComboBox.ItemContainerStyle>
            </ComboBox>
            <Button
              x:Name="ReloadButton"
              Click="ReloadButton_Click"
              Content="Reload"
              IsDefault="True"
              Style="{StaticResource MainHeaderButtonStyle}"
            />
            <Label
              Margin="18,0,0,0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Content="ソート順："
              FontSize="13"
              Foreground="{DynamicResource MainHeaderForegroundBrush}"
            />
            <ComboBox
              x:Name="ComboSort"
              Width="200"
              Margin="4,2,4,2"
              Background="{DynamicResource MainHeaderSortComboBackground}"
              FontSize="13"
              DisplayMemberPath="Name"
              Foreground="{DynamicResource MainHeaderInputForegroundBrush}"
              ItemsSource="{Binding SortLists}"
              SelectedValue="{Binding DbInfo.Sort}"
              SelectedValuePath="Id"
              SelectionChanged="ComboSort_SelectionChanged"
              Style="{StaticResource MainHeaderCompactComboBoxStyle}"
            />
            <TextBlock
              Margin="18,0,0,0"
              VerticalAlignment="Center"
              FontSize="13"
              Foreground="{DynamicResource MainHeaderForegroundBrush}">
              <Run Text="表示 / 登録  ：  " />
              <Run Text="{Binding DbInfo.SearchCount, Mode=OneWay}" />
              <Run Text=" / " />
              <Run
                Text="{Binding DbInfo.RegisteredMovieCount, Mode=OneWay}"
              />
            </TextBlock>
            <Label
              x:Name="lbDbFullPath"
              Margin="14,0,0,0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Content="{Binding DbInfo.DBFullPath, UpdateSourceTrigger=PropertyChanged}"
              FontSize="13"
              Foreground="{DynamicResource MainHeaderForegroundBrush}"
            />
          </VirtualizingStackPanel>
        </DockPanel>
      </materialDesign:ColorZone>
    </materialDesign:DrawerHost>

    <notifications:NotificationArea
      x:Name="ProgressArea"
      Position="BottomRight"
      Language="ja-JP"
      TextElement.FontFamily="Yu Gothic UI"
    />

    <StackPanel
      x:Name="PlayerArea"
      Width="Auto"
      Height="Auto"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Orientation="Vertical"
      Visibility="Collapsed"
    >
      <StackPanel.Effect>
        <DropShadowEffect
          BlurRadius="2"
          RenderingBias="Performance"
          ShadowDepth="10"
          Color="{DynamicResource PlayerShadowColor}"
        />
      </StackPanel.Effect>
      <MediaElement
        x:Name="uxVideoPlayer"
        Grid.Row="0"
        Width="900"
        Height="Auto"
        LoadedBehavior="Manual"
        MediaOpened="UxVideoPlayer_MediaOpened"
        PreviewMouseDown="UxVideoPlayer_PreviewMouseDown"
        ScrubbingEnabled="true"
        Stretch="Uniform"
        UnloadedBehavior="Stop"
      />
      <StackPanel
        x:Name="PlayerController"
        Grid.Row="1"
        Width="Auto"
        Background="{DynamicResource PlayerControllerBackground}"
        Orientation="Horizontal"
        Visibility="Collapsed"
      >
        <RepeatButton
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="FR_Click"
          Content="{materialDesign:PackIcon Kind=Rewind}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="戻す"
        />
        <Button
          x:Name="PlayButton"
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="Start_Click"
          Content="{materialDesign:PackIcon Kind=Play}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="再生"
        />
        <RepeatButton
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="FF_Click"
          Content="{materialDesign:PackIcon Kind=FastForward}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="送る"
        />
        <Button
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="Pause_Click"
          Content="{materialDesign:PackIcon Kind=PauseBox}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="一時停止"
        />
        <Button
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="Capture_Click"
          Content="{materialDesign:PackIcon Kind=Camera}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="サムネイルの取得"
        />
        <Button
          Margin="5"
          Background="{x:Null}"
          BorderThickness="0"
          Click="AddBookmark_Click"
          Content="{materialDesign:PackIcon Kind=BookmarkAdd}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="ブックマークの追加"
        />
        <Slider
          x:Name="uxTimeSlider"
          Width="300"
          Height="20"
          Margin="5"
          IsSnapToTickEnabled="True"
          LostMouseCapture="UxTimeSlider_LostMouseCapture"
          PreviewMouseLeftButtonDown="UxTimeSlider_PreviewMouseLeftButtonDown"
          PreviewMouseLeftButtonUp="UxTimeSlider_PreviewMouseLeftButtonUp"
          SmallChange="2000"
          ToolTip="再生位置"
          ValueChanged="UxTimeSlider_ValueChanged"
          Value="0"
        />
        <TextBlock
          x:Name="uxTime"
          Width="Auto"
          Margin="20,0,0,0"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="{DynamicResource HeaderForeground}"
          ToolTip="再生時刻"
        />
        <Slider
          x:Name="uxVolumeSlider"
          Width="50"
          Height="20"
          MinWidth="50"
          Margin="20,0,0,0"
          Maximum="1"
          Minimum="0"
          ToolTip="音量調整"
          ValueChanged="UxVolumeSlider_ValueChanged"
          Value="0.5"
        />
        <TextBlock
          x:Name="uxVolume"
          Width="40"
          MinWidth="40"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="{DynamicResource HeaderForeground}"
          TextAlignment="Right"
          ToolTip="音量"
        />
        <Button
          Width="30"
          Height="30"
          Margin="20,0,0,0"
          Padding="0"
          Background="{x:Null}"
          BorderThickness="1"
          Click="Stop_Click"
          Content="{materialDesign:PackIcon Kind=Close}"
          Style="{StaticResource MaterialDesignIconButton}"
          ToolTip="終了"
        />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
