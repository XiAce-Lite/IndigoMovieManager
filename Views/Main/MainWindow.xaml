<Window
  x:Class="IndigoMovieManager.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
  xmlns:c="clr-namespace:IndigoMovieManager.Converter"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:IndigoMovieManager"
  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
  xmlns:prop="clr-namespace:IndigoMovieManager.Properties"
  xmlns:bookmarkTab="clr-namespace:IndigoMovieManager.BottomTabs.Bookmark"
  xmlns:extensionTab="clr-namespace:IndigoMovieManager.BottomTabs.Extension"
  xmlns:debugTab="clr-namespace:IndigoMovieManager.BottomTabs.Debug"
  xmlns:savedSearchTab="clr-namespace:IndigoMovieManager.BottomTabs.SavedSearch"
  xmlns:thumbnailErrorTab="clr-namespace:IndigoMovieManager.BottomTabs.ThumbnailError"
  xmlns:thumbnailProgressTab="clr-namespace:IndigoMovieManager.BottomTabs.ThumbnailProgress"
  xmlns:upperTabsCommon="clr-namespace:IndigoMovieManager.UpperTabs.Common"
  xmlns:rescueTab="clr-namespace:IndigoMovieManager.UpperTabs.Rescue"
  xmlns:duplicateVideosTab="clr-namespace:IndigoMovieManager.UpperTabs.DuplicateVideos"
  xmlns:view="clr-namespace:IndigoMovieManager.UserControls"
  xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
  x:Name="window"
  Title="Indigo Movie Manager"
  AllowDrop="True"
  Width="800"
  Height="Auto"
  PreviewDragOver="MainWindow_PreviewDragOver"
  Drop="MainWindow_Drop"
  mc:Ignorable="d"
>
  <Window.Resources>
    <c:FileSizeConverter x:Key="FileSizeConverter" />
    <c:NoLockImageConverter x:Key="noLockImageConverter" />
    <c:TagSummaryConverter x:Key="tagSummaryConverter" />
    <c:ThumbnailProgressPreviewConverter x:Key="thumbnailProgressPreviewConverter" />
    <upperTabsCommon:UpperTabImageSourceConverter x:Key="upperTabImageSourceConverter" />
    <Style x:Key="UpperTabListCellTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource UpperTabPanelForegroundBrush}" />
    </Style>
    <Style
      x:Key="UpperTabListRightAlignedCellTextStyle"
      BasedOn="{StaticResource UpperTabListCellTextStyle}"
      TargetType="TextBlock"
    >
      <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>
    <Style
      x:Key="UpperTabListWrappedCellTextStyle"
      BasedOn="{StaticResource UpperTabListCellTextStyle}"
      TargetType="TextBlock"
    >
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style
      x:Key="LeftDrawerButtonStyle"
      BasedOn="{StaticResource MaterialDesignFlatButton}"
      TargetType="Button"
    >
      <Setter Property="Foreground" Value="{DynamicResource LeftDrawerForegroundBrush}" />
    </Style>
    <!--  BoolToVisibilityConverter を追加  -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <ContextMenu x:Key="menuContext" FontSize="10" Opened="MenuContext_Opened">
      <MenuItem
        x:Name="PlayDefault"
        Click="PlayMovie_Click"
        Header="プレイヤーから開く(_E)"
        Icon="{materialDesign:PackIcon Kind=MoviePlay}"
        InputGestureText="ENTER"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="PlayFromThumb"
        Click="PlayMovie_Click"
        Header="サムネイルから開く(_H)"
        Icon="{materialDesign:PackIcon Kind=MoviePlay}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <Separator />
      <MenuItem
        x:Name="TagEdit"
        Click="TagEdit_Click"
        Header="タグ編集(_T)"
        Icon="{materialDesign:PackIcon Kind=Edit}"
        InputGestureText="F6"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="TagAdd"
        Click="TagAdd_Click"
        Header="タグ追加(_A)"
        Icon="{materialDesign:PackIcon Kind=AttachmentAdd}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="TagDelete"
        Click="TagDelete_Click"
        Header="タグ削除(_V)"
        Icon="{materialDesign:PackIcon Kind=RemoveBox}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="TagCopy"
        Click="TagCopy_Click"
        Header="タグコピー(_C)"
        Icon="{materialDesign:PackIcon Kind=ContentCopy}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="TagPaste"
        Click="TagPaste_Click"
        Header="タグ貼り付け(_V)"
        Icon="{materialDesign:PackIcon Kind=ContentPaste}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ScorePlus"
        Click="MenuScore_Click"
        Header="スコア +1 (_A)"
        Icon="{materialDesign:PackIcon Kind=Plus}"
        InputGestureText="+"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ScoreMinus"
        Click="MenuScore_Click"
        Header="スコア -1 (_S)"
        Icon="{materialDesign:PackIcon Kind=Minus}"
        InputGestureText="-"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <Separator />
      <MenuItem
        Click="CreateThumb_EqualInterval"
        Header="等間隔サムネイル作成(_I)"
        Icon="{materialDesign:PackIcon Kind=Create}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <!--- ランダムサムネイルと画像からはなしにした
                                                <MenuItem Header="ランダムサムネイル作成(_R)" Icon="{materialDesign:PackIcon Kind=CreateOutline}" />
                                                <MenuItem Header="画像からサムネイル作成(_P)" Icon="{materialDesign:PackIcon Kind=Image}" />
            -->
      <MenuItem
        x:Name="ManualThumbnail"
        Click="ManualThumbnail_Click"
        Header="マニュアルサムネイル作成(_U)"
        Icon="{materialDesign:PackIcon Kind=Manufacturing}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ThumbnailRescueMenu"
        Click="ThumbnailRescueMenu_Click"
        Header="サムネイル救済(_R)"
        Icon="{materialDesign:PackIcon Kind=ImageRefresh}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ThumbnailDarkHeavyBackgroundRescueMenu"
        Click="ThumbnailDarkHeavyBackgroundRescueMenu_Click"
        Header="黒多め背景救済(_K)"
        Icon="{materialDesign:PackIcon Kind=ImageFilterBlackWhite}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ThumbnailDarkHeavyBackgroundLiteRescueMenu"
        Click="ThumbnailDarkHeavyBackgroundLiteRescueMenu_Click"
        Header="黒多め背景救済Lite(_L)"
        Icon="{materialDesign:PackIcon Kind=ImageOutline}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="ThumbnailIndexRepairMenu"
        Click="ThumbnailIndexRepairMenu_Click"
        Header="インデックス再構築(_I)"
        Icon="{materialDesign:PackIcon Kind=AutoFix}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <Separator />
      <MenuItem
        x:Name="DeleteMovie"
        Click="DeleteMovieRecord_Click"
        Header="登録から削除(_D)"
        Icon="{materialDesign:PackIcon Kind=Delete}"
        InputGestureText="DELETE"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="FileCopy"
        Click="MenuCopyAndMove_Click"
        Header="ファイルをコピー(_C)"
        Icon="{materialDesign:PackIcon Kind=ContentCopy}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="CopyPath"
        Click="CopyPath_Click"
        Header="パスのコピー(_P)"
        Icon="{materialDesign:PackIcon Kind=FileDocumentOutline}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="FileMove"
        Click="MenuCopyAndMove_Click"
        Header="ファイルを移動(_M)"
        Icon="{materialDesign:PackIcon Kind=MoveToInbox}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="DeleteFile"
        Click="DeleteMovieRecord_Click"
        Header="ファイルを削除(_L)"
        Icon="{materialDesign:PackIcon Kind=RemoveCircle}"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <MenuItem
        x:Name="RenameFile"
        Click="RenameFile_Click"
        Header="ファイル名変更(_N)"
        Icon="{materialDesign:PackIcon Kind=Rename}"
        InputGestureText="F2"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <Separator />
      <MenuItem
        Click="OpenParentFolder_Click"
        Header="親フォルダを開く(_F)"
        Icon="{materialDesign:PackIcon Kind=FolderOpen}"
        InputGestureText="F12"
      >
        <MenuItem.Style>
          <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="1" />
          </Style>
        </MenuItem.Style>
      </MenuItem>
      <!-- この辺はウィンドウ作らないといけないので劣後だろうな。
                                                <MenuItem Header="プロパティ(_P)" Icon="{materialDesign:PackIcon Kind=PropertyTag}" InputGestureText="P">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Padding" Value="1" />
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
            -->
    </ContextMenu>
  </Window.Resources>

  <Window.Background>
    <DynamicResource ResourceKey="MaterialDesignPaper" />
  </Window.Background>

  <Grid>
    <avalonDock:DockingManager x:Name="uxDockingManager" Margin="0,48,0,0">
      <avalonDock:DockingManager.Theme>
        <DynamicResource ResourceKey="AvalonDockTheme" />
      </avalonDock:DockingManager.Theme>
      <avalonDock:LayoutRoot>
        <avalonDock:LayoutPanel Orientation="Vertical">
          <avalonDock:LayoutPanel
            CanDock="False"
            CanRepositionItems="False"
            Orientation="Horizontal"
          >
            <avalonDock:LayoutDocumentPane
              x:Name="uxDocumentPane"
              CanRepositionItems="False"
              ShowHeader="False"
            >
              <!--  ドキュメント  ★ここから  -->
              <avalonDock:LayoutDocument Title="Document1" ContentId="Document1">
                <TabControl
                  x:Name="Tabs"
                  Margin="0,0,0,0"
                  PreviewKeyDown="Tab_PreviewKeyDown"
                  SelectionChanged="Tabs_SelectionChangedAsync"
                >
                  <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
                      <Setter Property="Height" Value="36" />
                      <Setter Property="Padding" Value="16,6,16,6" />
                    </Style>
                  </TabControl.Resources>
                  <TabItem x:Name="TabSmall" Background="{DynamicResource UpperTabBackground}" Header="Small" Tag="120x90x3x1">
                    <ListView
                      x:Name="SmallList"
                      Height="Auto"
                      ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      SelectionChanged="List_SelectionChanged"
                      SelectionMode="Extended"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                    >
                      <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                          <vwp:VirtualizingWrapPanel
                            Orientation="Horizontal"
                            SpacingMode="None"
                            StretchItems="False"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                          />
                        </ItemsPanelTemplate>
                      </ListView.ItemsPanel>

                      <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                          <!--  内容更新時のバインドエラー回避のおまじない。  -->
                          <Setter Property="Margin" Value="0" />
                          <Setter Property="Padding" Value="0" />
                          <Setter Property="Background" Value="Transparent" />
                          <Setter Property="BorderBrush" Value="Transparent" />
                          <Setter Property="BorderThickness" Value="0" />
                          <Setter Property="HorizontalAlignment" Value="Left" />
                          <Setter Property="HorizontalContentAlignment" Value="Left" />
                          <Setter Property="VerticalContentAlignment" Value="Top" />
                          <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                          <EventSetter
                            Event="PreviewMouseLeftButtonDown"
                            Handler="SmallListItem_PreviewMouseLeftButtonDown"
                          />
                        </Style>
                      </ListView.ItemContainerStyle>

                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <StackPanel>
                            <StackPanel Orientation="Horizontal">
                              <Label
                                Width="288"
                                Height="72"
                                Padding="0"
                                BorderThickness="0"
                                Background="{DynamicResource ThumbImageBackground}"
                                MouseDoubleClick="PlayMovie_Click"
                                MouseDown="Label_MouseDown"
                              >
                                <Image ContextMenu="{StaticResource menuContext}" Stretch="Uniform">
                                  <Image.Source>
                                    <MultiBinding
                                      Converter="{StaticResource upperTabImageSourceConverter}"
                                      ConverterParameter="{x:Static upperTabsCommon:UpperTabDecodeProfile.SmallDecodePixelHeight}"
                                    >
                                      <Binding Path="ThumbPathSmall" />
                                      <Binding Path="IsExists" />
                                      <Binding
                                        Path="IsSelected"
                                        RelativeSource="{RelativeSource AncestorType=TabItem}"
                                      />
                                    </MultiBinding>
                                  </Image.Source>
                                </Image>
                              </Label>

                              <view:SmallDetailControl VerticalAlignment="Top" />
                            </StackPanel>

                            <ItemsControl
                              Height="Auto"
                              ItemsSource="{Binding Tag, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                              Width="439"
                            >
                              <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                  <Style.Triggers>
                                    <Trigger Property="HasItems" Value="True">
                                      <Setter Property="Visibility" Value="Visible" />
                                    </Trigger>
                                  </Style.Triggers>
                                </Style>
                              </ItemsControl.Style>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <view:TagControl DataContext="{Binding}" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>

                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel
                                    Width="439"
                                    Height="Auto"
                                    MaxHeight="110"
                                  />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                            </ItemsControl>
                          </StackPanel>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </TabItem>

                  <TabItem x:Name="TabBig" Background="{DynamicResource UpperTabBackground}" Header="Big" Tag="200x150x3x1">
                    <ListView
                      x:Name="BigList"
                      ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      SelectionChanged="List_SelectionChanged"
                      SelectionMode="Extended"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                    >
                      <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                          <vwp:VirtualizingWrapPanel
                            Orientation="Horizontal"
                            StretchItems="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.ScrollUnit="Pixel"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                          />
                        </ItemsPanelTemplate>
                      </ListView.ItemsPanel>

                      <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                          <!--  内容更新時のバインドエラー回避のおまじない。  -->
                          <Setter Property="HorizontalContentAlignment" Value="Left" />
                          <Setter Property="VerticalContentAlignment" Value="Stretch" />
                          <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                          <EventSetter
                            Event="PreviewMouseLeftButtonDown"
                            Handler="BigListItem_PreviewMouseLeftButtonDown"
                          />
                        </Style>
                      </ListView.ItemContainerStyle>

                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <VirtualizingStackPanel
                            Orientation="Horizontal"
                            ScrollViewer.IsDeferredScrollingEnabled="true"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                          >
                            <VirtualizingStackPanel
                              Orientation="Vertical"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                            >
                              <view:BigTitleControl DataContext="{Binding}" />

                              <Label
                                Width="600"
                                Height="150"
                                MouseDoubleClick="PlayMovie_Click"
                                MouseDown="Label_MouseDown"
                              >
                                <Image
                                  ContextMenu="{StaticResource menuContext}"
                                  Stretch="Uniform"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                >
                                  <Image.Source>
                                    <MultiBinding
                                      Converter="{StaticResource upperTabImageSourceConverter}"
                                      ConverterParameter="{x:Static upperTabsCommon:UpperTabDecodeProfile.BigDecodePixelHeight}"
                                    >
                                      <Binding Path="ThumbPathBig" />
                                      <Binding Path="IsExists" />
                                      <Binding
                                        Path="IsSelected"
                                        RelativeSource="{RelativeSource AncestorType=TabItem}"
                                      />
                                    </MultiBinding>
                                  </Image.Source>
                                </Image>
                              </Label>
                            </VirtualizingStackPanel>

                            <view:BigDetailControl DataContext="{Binding}" />
                          </VirtualizingStackPanel>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </TabItem>

                  <TabItem x:Name="TabGrid" Background="{DynamicResource UpperTabBackground}" Header="Grid" Tag="160x120x1x1">
                    <ListView
                      x:Name="GridList"
                      ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      SelectionChanged="List_SelectionChanged"
                      SelectionMode="Extended"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                    >
                      <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                          <vwp:VirtualizingWrapPanel
                            Orientation="Horizontal"
                            SpacingMode="None"
                            StretchItems="False"
                            VirtualizingPanel.IsVirtualizing="True"
                          />
                        </ItemsPanelTemplate>
                      </ListView.ItemsPanel>

                      <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                          <!--  内容更新時のバインドエラー回避のおまじない。  -->
                          <Setter Property="Margin" Value="0" />
                          <Setter Property="Padding" Value="0" />
                          <Setter Property="HorizontalAlignment" Value="Left" />
                          <Setter Property="HorizontalContentAlignment" Value="Left" />
                          <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                      </ListView.ItemContainerStyle>

                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <Label
                            Width="160"
                            Height="120"
                            Padding="0"
                            BorderThickness="0"
                            ContextMenu="{StaticResource menuContext}"
                            MouseDoubleClick="PlayMovie_Click"
                            MouseDown="Label_MouseDown"
                          >
                            <Grid ClipToBounds="True">
                              <Image
                                Stretch="Uniform"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.ScrollUnit="Pixel"
                                VirtualizingPanel.VirtualizationMode="Recycling"
                              >
                                <Image.Source>
                                  <MultiBinding
                                    Converter="{StaticResource upperTabImageSourceConverter}"
                                    ConverterParameter="{x:Static upperTabsCommon:UpperTabDecodeProfile.GridDecodePixelHeight}"
                                  >
                                    <Binding Path="ThumbPathGrid" />
                                    <Binding Path="IsExists" />
                                    <Binding
                                      Path="IsSelected"
                                      RelativeSource="{RelativeSource AncestorType=TabItem}"
                                    />
                                  </MultiBinding>
                                </Image.Source>
                              </Image>

                              <Border
                                VerticalAlignment="Bottom"
                                Background="#99000000"
                                Padding="4,2"
                                IsHitTestVisible="False"
                              >
                                <TextBlock
                                  FontSize="11"
                                  Foreground="{DynamicResource GridTabTitleForegroundBrush}"
                                  Text="{Binding Movie_Name, UpdateSourceTrigger=PropertyChanged}"
                                  TextTrimming="CharacterEllipsis"
                                  ToolTip="{Binding Movie_Path}"
                                />
                              </Border>
                            </Grid>
                          </Label>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </TabItem>

                  <TabItem x:Name="TabList" Header="List" Tag="56x42x5x1">
                    <DataGrid
                      x:Name="ListDataGrid"
                      AutoGenerateColumns="False"
                      BeginningEdit="ListDataGrid_BeginningEdit"
                      CanUserAddRows="False"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      HorizontalScrollBarVisibility="Visible"
                      IsReadOnly="True"
                      ItemsSource="{Binding FilteredMovieRecs, UpdateSourceTrigger=PropertyChanged}"
                      SelectionChanged="List_SelectionChanged"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                    >
                      <DataGrid.RowStyle>
                        <Style BasedOn="{StaticResource {x:Type DataGridRow}}" TargetType="DataGridRow">
                          <Setter Property="ContextMenu" Value="{StaticResource menuContext}" />
                        </Style>
                      </DataGrid.RowStyle>

                      <DataGrid.Columns>
                        <DataGridTemplateColumn
                          Width="314"
                          MinWidth="314"
                          CanUserResize="false"
                          Header="サムネイル"
                        >
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:MovieRecords}">
                              <Label
                                Height="Auto"
                                MouseDoubleClick="PlayMovie_Click"
                                MouseDown="Label_MouseDown"
                              >
                                <Image
                                  Stretch="Uniform"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                >
                                  <Image.Source>
                                    <MultiBinding
                                      Converter="{StaticResource upperTabImageSourceConverter}"
                                      ConverterParameter="{x:Static upperTabsCommon:UpperTabDecodeProfile.ListDecodePixelHeight}"
                                    >
                                      <Binding Path="ThumbPathList" />
                                      <Binding Path="IsExists" />
                                      <Binding
                                        Path="IsSelected"
                                        RelativeSource="{RelativeSource AncestorType=TabItem}"
                                      />
                                    </MultiBinding>
                                  </Image.Source>
                                </Image>
                              </Label>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn CanUserSort="True" Header="ファイル名">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <VirtualizingStackPanel
                                Orientation="Vertical"
                                ScrollViewer.IsDeferredScrollingEnabled="true"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling"
