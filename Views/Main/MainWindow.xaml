            <avalonDock:LayoutAnchorable
              x:Name="exDetail"
              Title="詳細"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="False"
              ContentId="ToolExtension"
            >
              <extensionTab:ExtensionTabView x:Name="ExtensionTabViewHost" />
            </avalonDock:LayoutAnchorable>

            <avalonDock:LayoutAnchorable
              x:Name="exBookMark"
              Title="ブックマーク"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="False"
              ContentId="ToolBookmark"
            >
              <bookmarkTab:BookmarkTabView x:Name="BookmarkTabViewHost" DataContext="{Binding}" />
            </avalonDock:LayoutAnchorable>
            <!--  ツールウィンドウ  -->
            <avalonDock:LayoutAnchorable
              x:Name="TagBar"
              Title="保存済み検索条件"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="False"
              ContentId="ToolTagBar"
            >
              <savedSearchTab:SavedSearchTabView x:Name="SavedSearchTabViewHost" />
            </avalonDock:LayoutAnchorable>

            <avalonDock:LayoutAnchorable
              x:Name="ThumbnailProgressTab"
              Title="サムネイル進捗"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="False"
              IsSelected="True"
              ContentId="ToolThumbnailProgress"
            >
              <thumbnailProgressTab:ThumbnailProgressTabView
                x:Name="ThumbnailProgressTabViewHost"
                DataContext="{Binding}"
                GpuDecodeEnabledClicked="ThumbnailProgressGpuDecodeEnabled_Click"
                MissingThumbnailScanRequested="ThumbnailProgressMissingScan_Click"
                ParallelismSliderValueChanged="ThumbnailProgressParallelismSlider_ValueChanged"
                PresetFastRequested="ThumbnailProgressPresetFastButton_Click"
                PresetMaxRequested="ThumbnailProgressPresetMaxButton_Click"
                PresetLowLoadRequested="ThumbnailProgressPresetLowLoadButton_Click"
                PresetNormalRequested="ThumbnailProgressPresetNormalButton_Click"
                PresetSsdRequested="ThumbnailProgressPresetSsdButton_Click"
                SlowLaneMinGbSliderValueChanged="ThumbnailProgressSlowLaneMinGbSlider_ValueChanged"
              />
            </avalonDock:LayoutAnchorable>

            <avalonDock:LayoutAnchorable
              x:Name="ThumbnailErrorBottomTab"
              Title="サムネ失敗Debug"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="False"
              ContentId="ToolThumbnailError"
            >
              <thumbnailErrorTab:ThumbnailErrorTabView
                x:Name="ThumbnailErrorBottomTabViewHost"
                ClearListRequested="ClearThumbnailErrorListButton_Click"
                DataContext="{Binding}"
                ErrorListSelectionChangedRequested="List_SelectionChanged"
                ReloadRequested="ReloadThumbnailErrorListButton_Click"
                RescueAllRequested="RescueAllThumbnailErrorsButton_Click"
                RescueSelectedRequested="RescueSelectedThumbnailErrorsButton_Click"
              />
            </avalonDock:LayoutAnchorable>

            <avalonDock:LayoutAnchorable
              x:Name="DebugTab"
              Title="Debug"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="True"
              ContentId="ToolDebug"
            >
              <debugTab:DebugTabView
                x:Name="DebugTabViewHost"
                ClearCurrentDbRecordsRequested="DebugClearCurrentDbRecords_Click"
                ClearQueueDbRecordsRequested="DebugClearQueueDbRecords_Click"
                DeleteCurrentDbRequested="DebugDeleteCurrentDb_Click"
                DeleteQueueDbRequested="DebugDeleteQueueDb_Click"
                DeleteThumbnailDirRequested="DebugDeleteThumbnailDir_Click"
                OpenAppDataDirRequested="DebugOpenAppDataDir_Click"
                OpenCurrentDirRequested="DebugOpenCurrentDir_Click"
                OpenThumbDirRequested="DebugOpenThumbDir_Click"
                OpenDbDirRequested="DebugOpenDbDir_Click"
                OpenLogDirRequested="DebugOpenLogDir_Click"
                OpenFailureDbDirRequested="DebugOpenFailureDbDir_Click"
                ClearFailureDbRecordsRequested="DebugClearFailureDbRecords_Click"
                DeleteFailureDbRequested="DebugDeleteFailureDb_Click"
                RefreshFailureDbRecordCountRequested="DebugRefreshFailureDbRecordCount_Click"
                OpenCurrentDbDirRequested="DebugOpenCurrentDbDir_Click"
                OpenQueueDbDirRequested="DebugOpenQueueDbDir_Click"
                OpenThumbnailDirRequested="DebugOpenThumbnailDir_Click"
                RefreshCurrentDbRecordCountRequested="DebugRefreshCurrentDbRecordCount_Click"
                RefreshQueueDbRecordCountRequested="DebugRefreshQueueDbRecordCount_Click"
                RecreateAllThumbnailsRequested="DebugRecreateAllThumbnails_Click"
              />
            </avalonDock:LayoutAnchorable>

            <avalonDock:LayoutAnchorable
              x:Name="LogTab"
              Title="Log"
              AutoHideHeight="200"
              CanAutoHide="True"
              CanClose="False"
              CanDockAsTabbedDocument="False"
              CanHide="True"
              ContentId="ToolLog"
            >
              <logTab:LogTabView
                x:Name="LogTabViewHost"
                OpenLogDirRequested="DebugOpenLogDir_Click"
                RefreshPreviewRequested="LogRefreshPreview_Click"
                SwitchChangedRequested="LogTabSwitchChanged_Click"
              />
            </avalonDock:LayoutAnchorable>
          </avalonDock:LayoutAnchorablePane>
        </avalonDock:LayoutPanel>
      </avalonDock:LayoutRoot>
    </avalonDock:DockingManager>

    <materialDesign:DrawerHost IsLeftDrawerOpen="{Binding IsChecked, ElementName=MenuToggleButton}">
      <materialDesign:DrawerHost.LeftDrawerContent>
        <DockPanel MinWidth="220">
          <ToggleButton
            Margin="16"
            HorizontalAlignment="Right"
            DockPanel.Dock="Top"
            IsChecked="{Binding IsChecked, ElementName=MenuToggleButton, Mode=TwoWay}"
            Style="{StaticResource MaterialDesignHamburgerToggleButton}"
          />

          <VirtualizingStackPanel
            Margin="16,4"
            VirtualizingPanel.IsVirtualizing="true"
            VirtualizingPanel.VirtualizationMode="Recycling"
          >
            <Button
              x:Name="BtnNew"
              Margin="9,0,0,0"
              HorizontalAlignment="Left"
              Click="BtnNew_Click"
              Style="{StaticResource LeftDrawerButtonStyle}"
            >
              <DockPanel>
                <materialDesign:PackIcon Kind="FolderAdd" />
                <TextBlock Margin="10,0" Text="新規作成" />
              </DockPanel>
            </Button>

            <Button
              x:Name="BtnOpen"
              Margin="9,0,0,0"
              HorizontalAlignment="Left"
              Click="BtnOpen_Click"
              Style="{StaticResource LeftDrawerButtonStyle}"
            >
              <DockPanel>
                <materialDesign:PackIcon Kind="FolderOpen" />
                <TextBlock Margin="10,0" Text="ファイルを開く" />
              </DockPanel>
            </Button>

            <TreeView
              x:Name="MenuRecent"
              Margin="0,0,0,0"
              ItemsSource="{Binding RecentTreeRoot, UpdateSourceTrigger=PropertyChanged}"
            >
              <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                  <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                  <Setter Property="VerticalContentAlignment" Value="Center" />
                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
              </TreeView.Resources>

              <TreeView.ItemTemplate>
                <HierarchicalDataTemplate
                  DataType="{x:Type local:TreeSource}"
                  ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}"
                >
                  <Button
                    Margin="1,0,1,0"
                    Padding="4,4,0,6"
                    HorizontalAlignment="Left"
                    Click="MenuRecentTree_Click"
                    FontSize="14"
                    FontWeight="Bold"
                    Style="{StaticResource LeftDrawerButtonStyle}"
                    Tag="{Binding Text}"
                  >
                    <DockPanel>
                      <materialDesign:PackIcon VerticalAlignment="Center" Kind="File" />
                      <TextBlock
                        Margin="10,4,10,2"
                        VerticalAlignment="Center"
                        Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{Binding Text}"
                      />
                    </DockPanel>
                  </Button>
                </HierarchicalDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>

            <TreeView
              x:Name="MenuConfig"
              ItemsSource="{Binding ConfigTreeRoot, UpdateSourceTrigger=PropertyChanged}"
              Style="{StaticResource MaterialDesignTreeView}"
            >
              <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                  <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                  <Setter Property="VerticalContentAlignment" Value="Center" />
                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
              </TreeView.Resources>

              <TreeView.ItemTemplate>
                <HierarchicalDataTemplate
                  DataType="{x:Type local:TreeSource}"
                  ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}"
                >
                  <Button
                    Margin="1,0,1,0"
                    Padding="4,4,0,6"
                    HorizontalAlignment="Left"
                    Click="MenuBtnSettings_Click"
                    FontSize="14"
                    FontWeight="Bold"
                    Style="{StaticResource LeftDrawerButtonStyle}"
                    Tag="{Binding Text}"
                  >
                    <DockPanel>
                      <materialDesign:PackIcon
                        VerticalAlignment="Center"
                        Kind="{Binding IconKind}"
                      />
                      <TextBlock
                        Margin="10,4,10,2"
                        VerticalAlignment="Center"
                        Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{Binding Text}"
                      />
                    </DockPanel>
                  </Button>
                </HierarchicalDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>

            <TreeView
              x:Name="MenuTool"
              ItemsSource="{Binding ToolTreeRoot, UpdateSourceTrigger=PropertyChanged}"
              Style="{StaticResource MaterialDesignTreeView}"
            >
              <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                  <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                  <Setter Property="VerticalContentAlignment" Value="Center" />
                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
              </TreeView.Resources>

              <TreeView.ItemTemplate>
                <HierarchicalDataTemplate
                  DataType="{x:Type local:TreeSource}"
                  ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}"
                >
                  <Button
                    Margin="1,0,1,0"
                    Padding="4,4,0,6"
                    HorizontalAlignment="Left"
                    Click="MenuBtnTool_Click"
                    FontSize="14"
                    FontWeight="Bold"
                    Style="{StaticResource LeftDrawerButtonStyle}"
                    Tag="{Binding Text}"
                  >
                    <DockPanel>
                      <materialDesign:PackIcon
                        VerticalAlignment="Center"
                        Kind="{Binding IconKind}"
                      />
                      <TextBlock
                        Margin="10,4,10,2"
                        VerticalAlignment="Center"
                        Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{Binding Text}"
                      />
                    </DockPanel>
                  </Button>
                </HierarchicalDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>

            <Button
              x:Name="BtnExit"
              Margin="9,0,0,0"
              HorizontalAlignment="Left"
              Click="BtnExit_Click"
              Style="{StaticResource LeftDrawerButtonStyle}"
            >
              <DockPanel>
                <materialDesign:PackIcon VerticalAlignment="Center" Kind="ExitToApp" />
                <TextBlock Margin="10,0" VerticalAlignment="Center" Text="終了" />
              </DockPanel>
            </Button>
          </VirtualizingStackPanel>
        </DockPanel>
      </materialDesign:DrawerHost.LeftDrawerContent>

      <materialDesign:ColorZone
        x:Name="MainHeaderBar"
        Padding="10,6"
        Mode="Custom"
        Background="{DynamicResource MainHeaderBackground}"
        Foreground="{DynamicResource MainHeaderForegroundBrush}"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <ToggleButton
            x:Name="MenuToggleButton"
            Grid.Column="0"
            AutomationProperties.Name="HamburgerToggleButton"
            Width="32"
            Height="32"
            Margin="0,2,12,2"
            Checked="MenuToggleButton_Checked"
            Unchecked="MenuToggleButton_Unchecked"
            VerticalAlignment="Center"
            Style="{DynamicResource MaterialDesignHamburgerToggleButton}"
          />

          <Grid Grid.Column="1">
            <VirtualizingStackPanel
              x:Name="MainHeaderStandardChromePanel"
              Orientation="Horizontal"
              VirtualizingPanel.IsVirtualizing="true"
              VirtualizingPanel.VirtualizationMode="Recycling"
            >
              <ComboBox
                x:Name="SearchBox"
                Width="326"
                Margin="0,0,10,0"
                Padding="4,3,0,3"
                HorizontalContentAlignment="Stretch"
                materialDesign:HintAssist.Hint="検索キーワードを入れて下さい。"
                materialDesign:HintAssist.IsFloating="True"
                materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                materialDesign:TextFieldAssist.HasClearButton="True"
                materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                materialDesign:TextFieldAssist.TextFieldCornerRadius="3"
                materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource MaterialDesignBody}"
                Background="{DynamicResource MainHeaderSearchBoxBackground}"
                Cursor=""
                DisplayMemberPath="Find_Text"
                DockPanel.Dock="Top"
                DropDownClosed="SearchBox_DropDownClosed"
                FontSize="13"
                Foreground="{DynamicResource MainHeaderInputForegroundBrush}"
                IsEditable="True"
                ItemsSource="{Binding HistoryRecs}"
                LostFocus="SearchBox_LostFocus"
                PreviewKeyDown="SearchBox_PreviewKeyDown"
                SelectedValue="{Binding DbInfo.SearchKeyword}"
                SelectedValuePath="Find_Text"
                SelectionChanged="SearchBox_SelectionChanged"
                SelectiveScrollingGrid.SelectiveScrollingOrientation="None"
                Style="{StaticResource MainHeaderSearchBoxStyle}"
                Text="{Binding DbInfo.SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                TextBoxBase.TextChanged="SearchBox_TextChanged"
              >
                <ComboBox.ItemContainerStyle>
                  <Style BasedOn="{StaticResource MaterialDesignComboBoxItemStyle}" TargetType="ComboBoxItem">
                    <!--  内容更新時のバインドエラー回避のおまじない。  -->
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <EventSetter Event="MouseMove" Handler="SearchBoxItem_MouseMove" />
                    <EventSetter
                      Event="PreviewMouseLeftButtonDown"
                      Handler="SearchBoxItem_PreviewMouseLeftButtonDown"
                    />
                    <Style.Triggers>
                      <!--  選択時の反転表示  -->
                      <Trigger Property="IsSelected" Value="True" />
                    </Style.Triggers>
                  </Style>
                </ComboBox.ItemContainerStyle>
              </ComboBox>
              <Button
                x:Name="BulkTagAssignButton"
                Margin="0,0,10,0"
                Click="BulkTagAssignButton_Click"
                Content="タグ付..."
                Style="{StaticResource MainHeaderButtonStyle}"
                ToolTip="現在の検索キーワードをタグとして、表示中の動画または選択中の動画へ追加します"
              />
              <Button
                x:Name="ReloadButton"
                Click="ReloadButton_Click"
                Content="再読込"
                IsDefault="True"
                Style="{StaticResource MainHeaderButtonStyle}"
                ToolTip="一覧再読込と監視フォルダ更新チェックを実行します"
              />
              <Label
                Margin="18,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="ソート順："
                FontSize="13"
                Foreground="{DynamicResource MainHeaderForegroundBrush}"
              />
              <ComboBox
                x:Name="ComboSort"
                Width="200"
                Margin="4,2,4,2"
                Background="{DynamicResource MainHeaderSortComboBackground}"
                FontSize="13"
                DisplayMemberPath="Name"
                Foreground="{DynamicResource MainHeaderInputForegroundBrush}"
                ItemsSource="{Binding SortLists}"
                SelectedValue="{Binding DbInfo.Sort}"
                SelectedValuePath="Id"
                SelectionChanged="ComboSort_SelectionChanged"
                Style="{StaticResource MainHeaderCompactComboBoxStyle}"
              />
              <TextBlock
                Margin="18,0,0,0"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="{DynamicResource MainHeaderForegroundBrush}">
                <Run Text="表示 / 登録  ：  " />
                <Run Text="{Binding DbInfo.SearchCount, Mode=OneWay}" />
                <Run Text=" / " />
                <Run
                  Text="{Binding DbInfo.RegisteredMovieCount, Mode=OneWay}"
                />
              </TextBlock>
              <Label
                x:Name="lbDbFullPath"
                Margin="14,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{Binding DbInfo.DBFullPath, UpdateSourceTrigger=PropertyChanged}"
                FontSize="13"
                Foreground="{DynamicResource MainHeaderForegroundBrush}"
              />
              <Border
                x:Name="ExternalSkinFallbackNoticeBorder"
                Margin="14,0,0,0"
                Padding="10,4"
                VerticalAlignment="Center"
                Background="#26FFB300"
                BorderBrush="#66FFB300"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed"
              >
                <StackPanel Orientation="Horizontal">
                  <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    VerticalAlignment="Center"
                    Kind="AlertOutline"
                  />
                  <TextBlock
                    x:Name="ExternalSkinFallbackNoticeText"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource MainHeaderForegroundBrush}"
                    TextTrimming="CharacterEllipsis"
                  />
                  <Button
                    x:Name="ExternalSkinFallbackRetryButton"
                    Margin="10,0,0,0"
                    Padding="8,2"
                    Click="ExternalSkinFallbackRetryButton_Click"
                    Content="再試行"
                    Style="{StaticResource MainHeaderButtonStyle}"
                  />
                  <Button
                    x:Name="ExternalSkinFallbackOpenRuntimeDownloadButton"
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Click="ExternalSkinFallbackOpenRuntimeDownloadButton_Click"
                    Content="Runtimeを入手"
                    Style="{StaticResource MainHeaderButtonStyle}"
                    Visibility="Collapsed"
                  />
                  <Button
                    x:Name="ExternalSkinFallbackOpenLogButton"
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Click="ExternalSkinFallbackOpenLogButton_Click"
                    Content="ログを開く"
                    Style="{StaticResource MainHeaderButtonStyle}"
                  />
                </StackPanel>
              </Border>
            </VirtualizingStackPanel>

            <!-- 外部 skin 表示中だけ、host 側は最小シェルへ切り替える。 -->
            <DockPanel
              x:Name="ExternalSkinMinimalChromePanel"
              LastChildFill="True"
              Visibility="Collapsed"
            >
              <StackPanel
                DockPanel.Dock="Right"
                Orientation="Horizontal"
                VerticalAlignment="Center"
              >
                <Button
                  x:Name="ExternalSkinMinimalReloadButton"
                  Margin="0,0,8,0"
                  Click="ExternalSkinMinimalReloadButton_Click"
                  Content="再読込"
                  Style="{StaticResource MainHeaderButtonStyle}"
                />
                <Button
                  x:Name="ExternalSkinBackToGridButton"
                  Margin="0,0,8,0"
                  Click="ExternalSkinBackToGridButton_Click"
                  Content="Gridへ戻る"
                  Style="{StaticResource MainHeaderButtonStyle}"
                />
                <Button
                  x:Name="ExternalSkinMinimalSettingsButton"
                  Click="ExternalSkinMinimalSettingsButton_Click"
                  Content="設定"
                  Style="{StaticResource MainHeaderButtonStyle}"
                />
              </StackPanel>

              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon
                  Width="18"
                  Height="18"
                  VerticalAlignment="Center"
                  Kind="PaletteSwatch"
                />
                <TextBlock
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  FontSize="13"
                  Foreground="{DynamicResource MainHeaderForegroundBrush}"
                  Text="外部スキン"
                />
                <Border
                  Width="1"
                  Height="18"
                  Margin="12,0"
                  VerticalAlignment="Center"
                  Background="{DynamicResource MainHeaderForegroundBrush}"
                  Opacity="0.35"
                />
                <TextBlock
                  VerticalAlignment="Center"
                  FontSize="13"
                  Foreground="{DynamicResource MainHeaderForegroundBrush}"
                  Text="{Binding DbInfo.DBName, UpdateSourceTrigger=PropertyChanged}"
                />
                <Border
                  Width="1"
                  Height="18"
                  Margin="12,0"
                  VerticalAlignment="Center"
                  Background="{DynamicResource MainHeaderForegroundBrush}"
                  Opacity="0.35"
                />
                <Grid VerticalAlignment="Center">
                  <!-- skin 切替はその場で完結させつつ、裏のテキストは既存テスト資産向けに同期を残す。 -->
                  <ComboBox
                    x:Name="ExternalSkinMinimalSkinSelector"
                    Width="170"
                    Background="{DynamicResource MainHeaderSortComboBackground}"
                    DisplayMemberPath="Name"
                    Foreground="{DynamicResource MainHeaderInputForegroundBrush}"
                    SelectedValuePath="Name"
                    SelectionChanged="ExternalSkinMinimalSkinSelector_SelectionChanged"
                    Style="{StaticResource MainHeaderCompactComboBoxStyle}"
                    TextSearch.TextPath="Name"
                  />
                  <TextBlock
                    x:Name="ExternalSkinMinimalSkinNameText"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{DynamicResource MainHeaderForegroundBrush}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="Collapsed"
                  />
                </Grid>
              </StackPanel>
            </DockPanel>
          </Grid>
        </Grid>
      </materialDesign:ColorZone>
    </materialDesign:DrawerHost>

    <notifications:NotificationArea
      x:Name="ProgressArea"
      Position="BottomRight"
      Language="ja-JP"
      TextElement.FontFamily="Yu Gothic UI"
    />

  </Grid>
</Window>
