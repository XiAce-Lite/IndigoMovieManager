                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                          <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                          </Trigger>
                                          <DataTrigger
                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}"
                                            Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </TextBlock.Style>
                                  </TextBlock>

