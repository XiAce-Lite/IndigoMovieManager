                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                  />
                                </Border>

                                <ControlTemplate.Triggers>
                                  <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemChrome" Property="Background" Value="#123A6E8A" />
                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#803A9AD9" />
                                  </Trigger>
                                  <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemChrome" Property="Background" Value="#203A6E8A" />
                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#FF3A9AD9" />
                                  </Trigger>
                                  <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                      <Condition Property="IsSelected" Value="True" />
                                      <Condition Property="Selector.IsSelectionActive" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="ItemChrome" Property="Background" Value="#163A6E8A" />
                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#AA3A9AD9" />
                                  </MultiTrigger>
                                </ControlTemplate.Triggers>
                              </ControlTemplate>
                            </Setter.Value>
                          </Setter>
                          <!--  ここを追加: ListViewItem内のどこをクリックしても選択状態にする  -->
                          <EventSetter
