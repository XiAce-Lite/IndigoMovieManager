<Window
  x:Class="IndigoMovieManager.SettingsWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="個別設定"
  Width="800"
  Height="370"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterOwner"
  mc:Ignorable="d"
>
  <Window.Background>
    <DynamicResource ResourceKey="MaterialDesignPaper" />
  </Window.Background>
  <Window.Foreground>
    <DynamicResource ResourceKey="SettingsForegroundBrush" />
  </Window.Foreground>
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="10" Orientation="Vertical">
        <Button
          x:Name="BtnReturn"
          Margin="10,6,0,6"
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Click="BtnReturn_Click"
          Content="戻る(_R)"
          FontWeight="Normal"
        />

        <StackPanel Orientation="Horizontal">
          <Label Width="170" Margin="5" Content="サムネイルフォルダー" FontSize="14" />
          <TextBox
            x:Name="ThumbFolder"
            Width="520"
            Margin="5"
            materialDesign:TextFieldAssist.HasClearButton="True"
            FontSize="14"
            IsReadOnly="True"
            Text="{Binding ThumbFolder}"
            ToolTip="{Binding ThumbFolder}"
          />
          <Button
            x:Name="OpenThumbFolder"
            Width="30"
            Height="30"
            Click="OpenFolderDialog_Click"
            Content="{materialDesign:PackIcon Kind=FolderOpen}"
            Style="{StaticResource MaterialDesignIconButton}"
          />
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Label Width="170" Margin="5" Content="ブックマークフォルダー" FontSize="14" />
          <TextBox
            x:Name="BookmarkFolder"
            Width="520"
            Margin="5"
            materialDesign:TextFieldAssist.HasClearButton="True"
            FontSize="14"
            IsReadOnly="True"
            Text="{Binding BookmarkFolder}"
            ToolTip="{Binding BookmarkFolder}"
          />
          <Button
            x:Name="OpenBookmarkFolder"
            Width="30"
            Height="30"
            Click="OpenFolderDialog_Click"
            Content="{materialDesign:PackIcon Kind=FolderOpen}"
            Style="{StaticResource MaterialDesignIconButton}"
          />
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Label Width="170" Margin="5" Content="再生プレイヤー" FontSize="14" />
          <TextBox
            x:Name="PlayerPrg"
            Width="520"
            Margin="5"
            materialDesign:TextFieldAssist.HasClearButton="True"
            FontSize="14"
            IsReadOnly="True"
            Text="{Binding PlayerPrg}"
            ToolTip="{Binding PlayerPrg}"
          />
          <Button
            x:Name="OpenDialogPlayer"
            Width="30"
            Height="30"
            Click="OpenDialogPlayer_Click"
            Content="{materialDesign:PackIcon Kind=FolderOpen}"
            Style="{StaticResource MaterialDesignIconButton}"
          />
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Label
            Width="170"
            Margin="5"
            Content="再生プレイヤーパラメータ"
            FontSize="14"
            ToolTip="&lt;ms&gt;と&lt;file&gt;の置換のみ対応"
          />
          <ComboBox
            x:Name="PlayerParam"
            Width="520"
            Margin="5"
            materialDesign:TextFieldAssist.HasClearButton="True"
            FontSize="14"
            IsEditable="True"
            Text="{Binding PlayerParam}"
            ToolTip="&lt;ms&gt;と&lt;file&gt;の置換のみ対応"
          />
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Label Width="170" Margin="5" Content="検索履歴の保持数" FontSize="14" />
          <TextBlock
            x:Name="KeepHistory"
            Width="50"
            Margin="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            FontSize="14"
            Text="{Binding KeepHistory}"
          />
          <Slider
            x:Name="slider"
            Width="450"
            Margin="16,0,0,0"
            VerticalAlignment="Center"
            Maximum="100"
            Minimum="1"
            Style="{StaticResource MaterialDesignDiscreteSlider}"
            TickFrequency="1"
            Value="{Binding KeepHistory}"
          />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
