<Window x:Class="IndigoReleaseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IndigoReleaseManager"
        Width="1520"
        Height="980"
        MinWidth="1320"
        MinHeight="860"
        Background="#0F172A"
        FontFamily="Yu Gothic UI">
  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#111827" Offset="0" />
        <GradientStop Color="#172554" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                Background="#CC0B1220"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="18">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock FontSize="28"
                         FontWeight="Bold"
                         Foreground="#F8FAFC"
                         Text="IndigoReleaseManager" />
              <TextBlock Margin="0,8,0,0"
                         FontSize="14"
                         Foreground="#CBD5E1"
                         Text="Private release / Public preview / Public release を順番どおり実行するための配布専用オーケストレータ" />
              <TextBlock Margin="0,6,0,0"
                         FontSize="13"
                         Foreground="#93C5FD"
                         Text="UI は現在地表示と既存 script の正面入口に徹し、build / publish / release ロジックはここで再実装しません。" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="20,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <TextBlock FontSize="12"
                         Foreground="#94A3B8"
                         Text="現在ステータス" />
              <TextBlock Width="280"
                         TextWrapping="Wrap"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,20,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  Margin="0,0,10,0"
                  Padding="18"
                  Background="#CC111827"
                  BorderBrush="#1D4ED8"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#DBEAFE"
                         Text="Public repo" />
              <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" Text="Owner / Repository" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PublicOwnerAccount}" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PublicRepositoryName}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Local path" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PublicRepoPath}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Branch" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PublicBranch}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Origin" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PublicOriginUrl}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Upstream" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PublicUpstreamUrl}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Private probe" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PublicPrivateProbeUrl}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Public version" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding Version}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Margin="10,0,0,0"
                  Padding="18"
                  Background="#CC111827"
                  BorderBrush="#059669"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#D1FAE5"
                         Text="Private repo" />
              <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" Text="Owner / Repository" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PrivateOwnerAccount}" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PrivateRepositoryName}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Local path" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PrivateRepoPath}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Branch" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PrivateBranch}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="Origin" />
              <TextBlock Foreground="#F8FAFC" TextWrapping="Wrap" Text="{Binding PrivateOriginUrl}" />
              <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Foreground="#E2E8F0" Text="Preflight" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="gh auth" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding GhAuthState}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="GH_TOKEN / GITHUB_TOKEN" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding GitHubTokenState}" />
              <TextBlock Margin="0,10,0,0" Foreground="#94A3B8" Text="INDIGO_ENGINE_REPO_TOKEN" />
              <TextBlock Foreground="#F8FAFC" Text="{Binding PrivateEngineTokenState}" />
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,20,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  Margin="0,0,12,0"
                  Padding="18"
                  Background="#CC0F172A"
                  BorderBrush="#2563EB"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#DBEAFE" Text="1. Private release 準備" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="#CBD5E1"
                         Text="v1 では Private local build / publish / package の後に、Public 側 prepared dir へ同期します。Private 側を更新した時だけ使います。" />
              <TextBlock Margin="0,16,0,0" Foreground="#94A3B8" Text="Version / VersionLabel" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" />
              <Button Margin="0,18,0,0"
                      Padding="12,10"
                      Click="RunPrivateRelease_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#2563EB"
                      Foreground="White"
                      BorderBrush="#2563EB"
                      Content="Private prepare と Public 同期を実行" />
              <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" Text="Last local output" />
              <TextBlock TextWrapping="Wrap" Foreground="#F8FAFC" Text="{Binding LastPrivateOutputPath}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Margin="6,0"
                  Padding="18"
                  Background="#CC0F172A"
                  BorderBrush="#0EA5E9"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#BFDBFE" Text="2. Public preview" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="#CBD5E1"
                         Text="Private release tag か run id を指定して preview workflow を起動し、WiX artifact まで proof します。" />
              <TextBlock Margin="0,16,0,0" Foreground="#94A3B8" Text="private_engine_release_tag" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding PrivateEngineReleaseTag, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,12,0,0" Foreground="#94A3B8" Text="private_engine_run_id (任意)" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding PrivateEngineRunId, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,12,0,0" Foreground="#94A3B8" Text="Public branch" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding PreviewRef, UpdateSourceTrigger=PropertyChanged}" />
              <Button Margin="0,18,0,0"
                      Padding="12,10"
                      Click="RunPublicPreview_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#0284C7"
                      Foreground="White"
                      BorderBrush="#0284C7"
                      Content="Public preview を実行" />
              <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" Text="Last preview URL" />
              <TextBlock TextWrapping="Wrap" Foreground="#F8FAFC" Text="{Binding LastPreviewUrl}" />
              <Button Margin="0,10,0,0"
                      Padding="10,8"
                      Click="OpenLastPreviewUrl_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#1E293B"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"
                      Content="Preview URL を開く" />
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Margin="12,0,0,0"
                  Padding="18"
                  Background="#CC0F172A"
                  BorderBrush="#22C55E"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#DCFCE7" Text="3. Public release" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="#CBD5E1"
                         Text="verify 済み app package と WiX installer を release へ公開します。既定では DryRun で安全側にしています。" />
              <TextBlock Margin="0,16,0,0" Foreground="#94A3B8" Text="Version" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,12,0,0" Foreground="#94A3B8" Text="private_engine_release_tag" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding PrivateEngineReleaseTag, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,12,0,0" Foreground="#94A3B8" Text="Public branch" />
              <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding ReleaseBranch, UpdateSourceTrigger=PropertyChanged}" />
              <WrapPanel Margin="0,14,0,0">
                <CheckBox Margin="0,0,16,8" Foreground="#E2E8F0" IsChecked="{Binding ReleaseDryRun}" Content="DryRun" />
                <CheckBox Margin="0,0,16,8" Foreground="#E2E8F0" IsChecked="{Binding ReleaseAllowDirty}" Content="AllowDirty" />
                <CheckBox Margin="0,0,16,8" Foreground="#E2E8F0" IsChecked="{Binding ReleaseSkipBranchPush}" Content="SkipBranchPush" />
                <CheckBox Margin="0,0,16,8" Foreground="#E2E8F0" IsChecked="{Binding ReleaseSkipTagPush}" Content="SkipTagPush" />
              </WrapPanel>
              <Button Margin="0,18,0,0"
                      Padding="12,10"
                      Click="RunPublicRelease_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#16A34A"
                      Foreground="White"
                      BorderBrush="#16A34A"
                      Content="Public release を実行" />
              <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" Text="Last release URL" />
              <TextBlock TextWrapping="Wrap" Foreground="#F8FAFC" Text="{Binding LastPublicReleaseUrl}" />
              <Button Margin="0,10,0,0"
                      Padding="10,8"
                      Click="OpenLastPublicReleaseUrl_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#1E293B"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"
                      Content="Release URL を開く" />
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,20,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  Margin="0,0,10,0"
                  Padding="18"
                  Background="#CC020617"
                  BorderBrush="#334155"
                  BorderThickness="1"
                  CornerRadius="18">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top"
                         Margin="0,0,0,12"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC"
                         Text="Execution log" />
              <TextBox VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Auto"
                       AcceptsReturn="True"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       Background="#020617"
                       Foreground="#E2E8F0"
                       BorderBrush="#1E293B"
                       Text="{Binding LogText}" />
            </DockPanel>
          </Border>

          <Border Grid.Column="1"
                  Margin="10,0,0,0"
                  Padding="18"
                  Background="#CC020617"
                  BorderBrush="#334155"
                  BorderThickness="1"
                  CornerRadius="18">
            <StackPanel>
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC"
                         Text="Quick actions" />
              <Button Margin="0,16,0,0"
                      Padding="12,10"
                      Click="RefreshEnvironment_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#1E293B"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"
                      Content="環境情報を再取得" />
              <Button Margin="0,12,0,0"
                      Padding="12,10"
                      Click="OpenPublicRepoUrl_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#1E293B"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"
                      Content="Public GitHub を開く" />
              <Button Margin="0,12,0,0"
                      Padding="12,10"
                      Click="OpenPrivateRepoUrl_Click"
                      IsEnabled="{Binding CanRunActions}"
                      Background="#1E293B"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"
                      Content="Private GitHub を開く" />
              <TextBlock Margin="0,18,0,0"
                         Foreground="#94A3B8"
                         Text="v1 方針" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="#CBD5E1"
                         Text="この app は orchestration に徹し、既存 PowerShell script と GitHub Actions を正本に使います。build / publish / release ロジックはここで再実装しません。" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </ScrollViewer>
  </Grid>
</Window>
